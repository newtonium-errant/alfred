# STAY-C — sovereign ambient clinical scribe (Jamie's NP-clinic instance)
#
# This is the REPO TEMPLATE (``.example``). Per-instance ``config.*.yaml`` are
# gitignored (they hold deploy-specific paths); at deploy, copy this to the box
# path referenced by the launch wrapper below:
#   /data/algernon/stayc-clinical/config.stayc-clinical.yaml
#
# scribe P1-d — the "STAY-C exists as a running sovereign instance" standup.
# On-box, LOCAL-MODEL-ONLY: local STT (faster-whisper) + local LLM (qwen via
# Ollama on loopback). This instance is PROVABLY unable to reach any cloud
# STT/TTS/LLM — the sovereign no-egress boundary (P1-a) is enforced at load
# and re-checked + http-guard-armed in the scribe daemon's own process.
#
# 🔒 FAIL-CLOSED / NO SECRETS. STAY-C needs ZERO secret keys — it is local-only.
# This config contains ONLY the barrier-(d) allowlisted top-level sections
# {instance, sovereign, scribe, vault, logging, daemon} (+ the synthetic
# _config_path stamped at load). There is NO `agent`, NO `transport`, NO
# `telegram`/`brief`/`mail`, NO cloud key, and NO ${...CLOUD_KEY} placeholder.
# Adding any non-allowlisted section makes the sovereign boundary REFUSE at
# load (exit 79, non-restartable). No transport section => NO network server
# binds => no port is needed.
#
# ── LAUNCH (cloud-key-SCRUBBED — the wrapper IS the sovereign guarantee) ──
# Launch STAY-C DIRECTLY with a scrubbed env, NOT via `alfred instance up`
# (the fan-out does not scrub the shell env):
#
#   env -u ANTHROPIC_API_KEY -u ANTHROPIC_AUTH_TOKEN -u ANTHROPIC_BASE_URL \
#       -u GROQ_API_KEY -u DEEPGRAM_API_KEY -u OPENAI_API_KEY \
#       -u OPENROUTER_API_KEY -u ELEVENLABS_API_KEY -u TOGETHER_API_KEY \
#       -u ZO_API_KEY -u RESEND_API_KEY \
#       alfred --config /data/algernon/stayc-clinical/config.stayc-clinical.yaml up
#
# Belt AND braces: the scrubbed env (env -u) removes cloud keys from the shell,
# AND there is no cloud-key sibling .env at /data/algernon/stayc-clinical/ to
# re-introduce them. Barrier (c) refuses at load if either fails.
#
# ── PERSISTENCE (preferred: hardened systemd SYSTEM unit — #42, hardened #67) ──
# For a box that must survive reboots + terminal exit, install the STANDALONE
# hardened unit instead of the manual env -u launch above (the manual launch
# stays a valid supervised-console fallback). It is a SYSTEM unit, not a --user
# unit: only a privileged system manager can apply the hardening (a --user
# manager dies status=218/CAPABILITIES), so install it via sudo with the STAY-C
# venv (so the ExecStart python is that venv, where faster-whisper lives):
#
#   sudo /data/algernon/stayc-clinical/.venv/bin/python \
#       -m alfred.scripts.install_stayc_unit --stage-model   # renders + installs
#   sudo systemctl start alfred-stayc-clinical.service
#
# The unit is STANDALONE — NOT a row in ~/.alfred/instances.yaml, NOT part of
# algernon.target. It manager-enforces the cloud-key scrub (UnsetEnvironment),
# an fs sandbox (ProtectSystem=strict, ReadWritePaths=vault+data+HF+input_dir),
# and a best-effort kernel egress belt (IPAddressDeny=any) that the scribe
# PROBES at boot but never trusts. The installer READS scribe.input_dir +
# scribe.stt.model from THIS config (so the sandbox + the offline STT-model
# check match the deploy). See the installer + the frozen spec for rollback.
#
# P1-d is the STANDUP only — the daemon boots in synthetic mode, validates the
# boundary, arms the http guard, emits `scribe.daemon.up`, and sits idle-ready.
# The audio→note pipeline is P2. `scribe.mode: synthetic` is the fail-closed
# legal line: the pipeline refuses any input without a `synthetic: true`
# provenance tag; flipping to `clinical` is a single deliberate edit gated on
# the legal de-id/attestation standard.

# ---------------------------------------------------------------------------
# Instance identity — templating/attribution only, no network surface.
# ---------------------------------------------------------------------------
instance:
  name: "STAY-C"
  canonical: "STAY-C"
  aliases: ["Stacy", "Stay-C"]

# ---------------------------------------------------------------------------
# Sovereign no-egress boundary — THE enablement gate. Presence + enabled:true
# arms the four-barrier gate at load AND the scribe daemon's self-check +
# http-guard self-install.
# ---------------------------------------------------------------------------
sovereign:
  enabled: true

# ---------------------------------------------------------------------------
# Scribe — local STT + local LLM. Barrier (a) validates stt.provider is on the
# local allowlist {faster-whisper, local-whisper, fake}; barrier (b) validates
# llm.base_url resolves to loopback. LOCAL-ONLY: no api_key, no cloud endpoint.
# ---------------------------------------------------------------------------
scribe:
  mode: synthetic          # FAIL-CLOSED default; flip to `clinical` (legal gate) is the LAST switch
  # MUST live UNDER the data dir (/data/algernon/stayc-clinical/data): the
  # hardened systemd unit grants write to {vault, data, models/hf} only
  # (ReadWritePaths); ProtectSystem=strict makes everything else read-only, so
  # an inbox that is a SIBLING of data would be EROFS and every encounter would
  # silently fail to fold. Keeping it inside data makes the ledger/chunk writes
  # land in a writable path.
  input_dir: "/data/algernon/stayc-clinical/data/inbox"
  # Per-instance SECRET that salts the opaque encounter_id (scribe P3-b1):
  #   encounter_id = "enc-" + hmac_sha256(encounter_salt, raw_label)[:16]
  # An UNsalted hash of a low-entropy patient label is trivially reversible, so
  # the salt is what makes the id non-reversible. FAIL-LOUD: the scribe refuses
  # to ingest any encounter until this is set. Provide via env — NEVER commit a
  # real salt inline. It is NEVER written to the vault, a log, or the audit.
  encounter_salt: "${SCRIBE_ENCOUNTER_SALT}"
  stt:
    provider: faster-whisper
    model: distil-large-v3
  llm:
    base_url: "http://127.0.0.1:11434"     # loopback Ollama — barrier (b) enforced
    model: "qwen2.5:14b-instruct-q4_K_M"
  # Multi-speaker diarization (scribe P4). Barrier (a-sibling) validates
  # diarize.provider is local {off, fake, pyannote}. Default OFF — notes draft
  # un-attributed until you deliberately enable the real engine.
  diarize:
    provider: off            # off (default) | fake (CI) | pyannote (real, on-box)
    enabled: false           # the real-engine kill-switch: pyannote + enabled:false is INERT
    # To enable the REAL engine (one-time, on-box):
    #   1. accept the HF conditions on pyannote/segmentation-3.0 +
    #      pyannote/speaker-diarization-3.1 (browser, same HF account as the token);
    #   2. stage the models + materialize the repo-id-free pipeline config:
    #        python -m alfred.scripts.stage_diarize_models \
    #          --hf-home /data/algernon/stayc-clinical/models/hf \
    #          --token-file ~/.secrets/hf_token
    #   3. set provider: pyannote, enabled: true, and pipeline_config to the printed path.
    # pipeline_config is the MATERIALIZED, repo-id-free config (absolute local paths);
    # an ENABLED pyannote with it unset/missing FAILS BOOT (exit 78) by design.
    # pipeline_config: "/data/algernon/stayc-clinical/models/hf/speaker-diarization-3.1.local.yaml"
    #
    # ── VOICE ENROLLMENT (P4-5) — named (user, mic, room) voice presets ──────────
    # enrollment_dir is the biometric store: preset files (EMBEDDINGS ONLY — the raw
    # audio is destroyed the moment the voiceprint is made), the enroll audit.log, and
    # the self-correcting capture sink. Created 0700; files 0600.
    # EMPTY (the default) = the whole enrollment feature is DORMANT: /scribe/enroll/*
    # refuses (503 enrollment_dormant) BEFORE any recording, and nothing is ever written.
    # NOTE: enrollment also requires provider: fake|pyannote — with provider: off the
    # enroll routes refuse up-front rather than waste a 45 s recording.
    # enrollment_dir: "/data/algernon/stayc-clinical/enrollment"
  # Designated human-clinician identities allowed to ATTEST a clinical_note
  # (scribe P2-a, #41). FAIL-CLOSED: an empty list = NO valid attester (every
  # `alfred scribe attest` refused). A plain identity list — NOT a network
  # field, so no boundary barrier applies. Deploy fills the real clinician ids
  # (e.g. "np_jamie"); the AI scribe drafter ("stayc_scribe") can never attest.
  #
  # ⚠️ DUAL-USE (P4-5): these ids are ALSO the voice-enrollment identity. Each entry
  # MUST be slug-shaped — ^[a-z0-9][a-z0-9._-]{0,63}$ (lowercase; no spaces) — because
  # it becomes a directory name under enrollment_dir, is matched VERBATIM (case-sensitive)
  # at /scribe/enroll/start, and is embedded in the served PWA page.
  # A non-slug entry ("NP Jamie") is DROPPED at config load with a loud
  # `scribe.config.invalid_clinician` error — so it can neither ENROLL *nor ATTEST*: the
  # id simply does not exist. Fail-closed and loud, rather than a half-valid identity that
  # attests fine and then fail-closes every enrollment with the clinician standing there
  # ready to record. Use "np_jamie".
  clinicians: []
  # ── LOOPBACK PWA INGEST SERVER (#49) + the P4-5 TWO-TOKEN CAPABILITY SPLIT ─────
  # INERT by default. When enabled, barrier (e) POSITIVELY asserts `host` is loopback at
  # config-load (a 0.0.0.0 bind fails at the BARRIER → exit 79) and requires `token`.
  # ingest_web:
  #   enabled: true
  #   host: 127.0.0.1          # loopback ONLY — barrier-e refuses anything else
  #   port: 8760
  #   # ENCOUNTER capability. The served page EMBEDS this token (its JS needs it).
  #   token: ${SCRIBE_INGEST_TOKEN}
  #   # BIOMETRIC-CUSTODY capability (P4-5) — a SEPARATE credential, because page
  #   # possession must NEVER grant enrollment / re-record / revoke. It is NEVER embedded
  #   # in the page: the enrolling clinician pastes it once (memory-only).
  #   #   * UNSET/EMPTY  ⇒ the whole enrollment face is INERT (routes 404).
  #   #   * IDENTICAL to `token` ⇒ REFUSED (fail-closed to inert + a loud error): an equal
  #   #     token collapses the split, since anyone holding the page holds the ingest token.
  #   #   * An UNRESOLVED ${SCRIBE_ENROLL_TOKEN} (env var not set at daemon start) is
  #   #     treated as EMPTY — the face stays INERT rather than arming with the literal,
  #   #     publicly-known placeholder string as its bearer.
  #   enroll_token: ${SCRIBE_ENROLL_TOKEN}
  # Kernel-egress belt PROBE (#42) — a SUBsection of scribe (barrier-d safe:
  # not a new top-level section). Best-effort observability ONLY: the daemon
  # never trusts or gates on it — the load-bearing egress control is the
  # sovereign boundary + the http guard. At boot the daemon connects (SYN only,
  # NO payload) to `canary` to probe whether the systemd IPAddressDeny belt is
  # live, and logs `scribe.egress_firewall.enforced` (EPERM — belt live, NO
  # packet left the box) or `.unverified` (belt unproven — Python guard is the
  # SOLE verified control). It also connects to `loopback` (Ollama) so an
  # IPAddressAllow over-block that severed the local model fails LOUD.
  #
  # ⚠️ When enabled:true the daemon fires ONE payload-free canary SYN at boot —
  # ONLY on the unverified path — toward a NON-ROUTABLE TEST-NET-1 address
  # (RFC 5737 192.0.2.1) that no host owns, so it NEVER touches a real cloud
  # host; it only proves whether the local kernel egress hook rejects it (EPERM
  # is synchronous, so when the belt IS enforced NO packet ever leaves). Set
  # enabled:false to suppress that SYN entirely (the daemon then logs
  # `scribe.egress_firewall.probe_disabled`).
  egress_probe:
    enabled: true
    canary: "192.0.2.1:443"        # TEST-NET-1 (RFC 5737) — NON-routable, never touches a real host; SYN only
    loopback: "127.0.0.1:11434"    # Ollama loopback — must stay reachable (real-need i)

# ---------------------------------------------------------------------------
# Vault — STAY-C's OWN PHI vault, physically separate from every other vault
# (Salem / KAL-LE / Hypatia / VERA). clinical_note records land here and NEVER
# leave the box (schema._NEVER_PUSH_TYPES + no transport wired).
# ---------------------------------------------------------------------------
vault:
  path: "/data/algernon/stayc-clinical/vault"
  dont_scan_dirs: ["_bases", ".obsidian"]
  dont_index_dirs: []
  ignore_files: [".gitkeep"]

# ---------------------------------------------------------------------------
# Logging — the scribe daemon logs to <dir>/scribe.log.
# ---------------------------------------------------------------------------
logging:
  level: "INFO"
  dir: "/data/algernon/stayc-clinical/data"

# ---------------------------------------------------------------------------
# Daemon — PID file location (filesystem only, per-instance collision-avoid).
# ---------------------------------------------------------------------------
daemon:
  pid_path: "/data/algernon/stayc-clinical/data/alfred.pid"
