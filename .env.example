# Alfred — Environment Variables
# Copy to .env and fill in your values

# Zo Computer API key (if using zo backend)
# ZO_API_KEY=your-zo-api-key-here

# OpenRouter API key (required for surveyor labeling)
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# Telegram bot token (talker tool)
# Get one from @BotFather on Telegram: https://t.me/BotFather
# TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-here

# Anthropic API key (talker tool — direct SDK, not claude -p)
# Get one from https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Groq API key (talker tool — Whisper STT)
# Get one from https://console.groq.com/keys
# GROQ_API_KEY=gsk_your-key-here

# ElevenLabs API key (talker tool — /brief audio summaries via Turbo v2.5)
# Get one from https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Outbound-push transport bearer token — shared secret between the
# talker's HTTP server and every tool that POSTs to it. Generate a
# fresh 64-char hex secret once per install:
#   python -c 'import secrets; print(secrets.token_hex(32))'
# Or run: alfred transport rotate
# ALFRED_TRANSPORT_TOKEN=your-64-char-hex-token-here

# ---------------------------------------------------------------------------
# Stage 3.5 multi-instance (KAL-LE + future STAY-C)
# ---------------------------------------------------------------------------
# Each of these needs its own secret. Use:
#   python -c 'import secrets; print(secrets.token_hex(32))'
# for every line below.

# KAL-LE's own Telegram bot (register via @BotFather with a new bot name).
# TELEGRAM_KALLE_BOT_TOKEN=123456:ABC-your-kalle-bot-token-here

# KAL-LE's local transport token — local tools on the KAL-LE host
# authenticate to KAL-LE's transport with this. Analogous to
# ALFRED_TRANSPORT_TOKEN on the Salem side.
# ALFRED_KALLE_TRANSPORT_TOKEN=your-64-char-hex-token-here

# Peer-pair tokens. Each side knows BOTH its own inbound peer token
# (used to verify inbound calls) AND the outbound peer token for the
# other side (used to authenticate to the peer). Symmetric pair:
#   ALFRED_KALLE_PEER_TOKEN  — Salem → KAL-LE (Salem sends this;
#                              KAL-LE's auth.tokens.salem validates it)
#   ALFRED_SALEM_PEER_TOKEN  — KAL-LE → Salem (KAL-LE sends this;
#                              Salem's auth.tokens.kal-le validates it)
# ALFRED_KALLE_PEER_TOKEN=your-64-char-hex-token-here
# ALFRED_SALEM_PEER_TOKEN=your-64-char-hex-token-here

# ---------------------------------------------------------------------------
# Google Calendar integration (Phase A+ — Salem only by default)
# ---------------------------------------------------------------------------
# Salem's /canonical/event/propose-create handler reads these to query
# Andrew's actual calendars for conflict-check and to push accepted
# events to a dedicated "Alfred" calendar visible on Andrew's phone.
# Set after running through the operator setup in config.yaml.example
# (gcal: block).

# Calendar ID for the dedicated "Alfred" calendar (R/W). Found in
# Google Calendar Settings → click on the calendar → Integrate calendar
# → "Calendar ID" (typically <hex>@group.calendar.google.com).
# ALFRED_GCAL_CALENDAR_ID=alfred-cal-id@group.calendar.google.com

# Primary calendar ID (R/O — Salem queries but never writes). Usually
# your Google account email.
# ALFRED_GCAL_PRIMARY_ID=your-email@gmail.com
