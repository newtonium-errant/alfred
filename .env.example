# Alfred — Environment Variables
# Copy to .env and fill in your values

# Zo Computer API key (if using zo backend)
# ZO_API_KEY=your-zo-api-key-here

# OpenRouter API key (required for surveyor labeling)
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# Telegram bot token (talker tool)
# Get one from @BotFather on Telegram: https://t.me/BotFather
# TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-here

# Anthropic API key (talker tool — direct SDK, not claude -p)
# Get one from https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Groq API key (talker tool — Whisper STT)
# Get one from https://console.groq.com/keys
# GROQ_API_KEY=gsk_your-key-here
