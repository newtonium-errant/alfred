# Alfred — Environment Variables
# Copy to .env and fill in your values

# Zo Computer API key (if using zo backend)
# ZO_API_KEY=your-zo-api-key-here

# OpenRouter API key (required for surveyor labeling)
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# Telegram bot token (talker tool)
# Get one from @BotFather on Telegram: https://t.me/BotFather
# TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-here

# Anthropic API key (talker tool — direct SDK, not claude -p)
# Get one from https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Groq API key (talker tool — Whisper STT)
# Get one from https://console.groq.com/keys
# GROQ_API_KEY=gsk_your-key-here

# ElevenLabs API key (talker tool — /brief audio summaries via Turbo v2.5;
# ALSO the web.voice TTS talk-back plane when web voice is enabled).
# Get one from https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Deepgram API key (web.voice assistant-pipeline streaming STT — nova-3).
# REQUIRED in every daemon's runtime env that enables web.voice with
# pipeline: assistant (session OR relay mode); an unresolved key fails the
# voice mount closed (loud web.voice.disabled reason=stt_key_missing).
# Get one from https://console.deepgram.com/
# DEEPGRAM_API_KEY=your-deepgram-api-key-here

# Outbound-push transport bearer token — shared secret between the
# talker's HTTP server and every tool that POSTs to it. Generate a
# fresh 64-char hex secret once per install:
#   python -c 'import secrets; print(secrets.token_hex(32))'
# Or run: alfred transport rotate
# ALFRED_TRANSPORT_TOKEN=your-64-char-hex-token-here

# ---------------------------------------------------------------------------
# Stage 3.5 multi-instance (KAL-LE + future STAY-C)
# ---------------------------------------------------------------------------
# Each of these needs its own secret. Use:
#   python -c 'import secrets; print(secrets.token_hex(32))'
# for every line below.

# KAL-LE's own Telegram bot (register via @BotFather with a new bot name).
# TELEGRAM_KALLE_BOT_TOKEN=123456:ABC-your-kalle-bot-token-here

# KAL-LE's local transport token — local tools on the KAL-LE host
# authenticate to KAL-LE's transport with this. Analogous to
# ALFRED_TRANSPORT_TOKEN on the Salem side.
# ALFRED_KALLE_TRANSPORT_TOKEN=your-64-char-hex-token-here

# Peer-pair tokens. Each side knows BOTH its own inbound peer token
# (used to verify inbound calls) AND the outbound peer token for the
# other side (used to authenticate to the peer). Symmetric pair:
#   ALFRED_KALLE_PEER_TOKEN  — Salem → KAL-LE (Salem sends this;
#                              KAL-LE's auth.tokens.salem validates it)
#   ALFRED_SALEM_PEER_TOKEN  — KAL-LE → Salem (KAL-LE sends this;
#                              Salem's auth.tokens.kal-le validates it)
# ALFRED_KALLE_PEER_TOKEN=your-64-char-hex-token-here
# ALFRED_SALEM_PEER_TOKEN=your-64-char-hex-token-here

# ---------------------------------------------------------------------------
# VERA→KAL-LE→GitHub ticket pipeline (per-direction peer tokens)
# ---------------------------------------------------------------------------
# The ticket pipeline runs in BOTH directions, each its own dedicated
# token (per feedback_per_peer_token_uniqueness.md — never share one
# token across two peer pairs):
#   ALFRED_VERA_TO_KALLE_TOKEN — VERA → KAL-LE (the kind=ticket intake
#                                push; KAL-LE's auth.tokens.vera
#                                validates it, allowed_clients [vera]).
#   ALFRED_KALLE_TO_VERA_TOKEN — KAL-LE → VERA (the c7 ticket-outcome
#                                write-back; VERA's auth.tokens.kalle
#                                validates it, allowed_clients [kal-le]).
# Both go in the live gitignored configs (config.kalle.yaml +
# config.vera.yaml); generate each with the token_hex(32) recipe above.
# ALFRED_VERA_TO_KALLE_TOKEN=your-64-char-hex-token-here
# ALFRED_KALLE_TO_VERA_TOKEN=your-64-char-hex-token-here

# ---------------------------------------------------------------------------
# Web PWA (chat + voice) — per-instance ``web`` peer tokens + session secret
# ---------------------------------------------------------------------------
# The Next BFF holds a DEDICATED ``web`` peer token PER INSTANCE (its own
# secret, distinct from that instance's ``web_ingest`` token and from every
# other instance's ``web`` token). This one token is Layer-1 authority for
# BOTH chat AND live voice on that instance (there is no separate voice
# token). Generate each with token_hex(32). The BFF side stores the SAME
# secret value in web/.env.local as ALFRED_WEB_CHAT_<INSTANCE>_TOKEN.
#   ALFRED_WEB_PEER_TOKEN          — Salem (home/session mode)
#   ALFRED_HYPATIA_WEB_PEER_TOKEN  — Hypatia (relay-mode voice + chat)
#   ALFRED_KALLE_WEB_PEER_TOKEN    — KAL-LE (relay-mode chat; voice by ruling)
# ALFRED_WEB_PEER_TOKEN=your-64-char-hex-token-here
# ALFRED_HYPATIA_WEB_PEER_TOKEN=your-64-char-hex-token-here
# ALFRED_KALLE_WEB_PEER_TOKEN=your-64-char-hex-token-here

# Session-mode ONLY (the home/login instance — Salem): the HMAC secret that
# signs web session + magic-link tokens, plus the public front-end origin.
# NOT needed on relay-mode instances (they never mint/verify session tokens).
# ALFRED_WEB_SESSION_SECRET=your-64-char-hex-token-here
# ALFRED_WEB_BASE_URL=https://your-cloudflared-subdomain.example.com

# ---------------------------------------------------------------------------
# Google Calendar integration (Phase A+ — Salem only by default)
# ---------------------------------------------------------------------------
# Salem's /canonical/event/propose-create handler reads these to query
# Andrew's actual calendars for conflict-check and to push accepted
# events to a dedicated "Alfred" calendar visible on Andrew's phone.
# Set after running through the operator setup in config.yaml.example
# (gcal: block).

# Calendar ID for the dedicated "Alfred" calendar (R/W). Found in
# Google Calendar Settings → click on the calendar → Integrate calendar
# → "Calendar ID" (typically <hex>@group.calendar.google.com).
# ALFRED_GCAL_CALENDAR_ID=alfred-cal-id@group.calendar.google.com

# Primary calendar ID (R/O — Salem queries but never writes). Usually
# your Google account email.
# ALFRED_GCAL_PRIMARY_ID=your-email@gmail.com

# ── Mail intake (config.yaml `mail:` section) ────────────────────────────────
# Bearer token the n8n workflow presents to the mail WEBHOOK receiver
# (POST /ingest). Must match the "Alfred Auth" header-auth credential in n8n.
# MAIL_WEBHOOK_TOKEN=your-webhook-bearer-token
#
# IMAP password for the live.ca (Outlook) account — used ONLY by the native
# IMAP fetcher (`alfred mail fetch` / the fetch loop); the webhook path needs
# no IMAP password. Outlook requires an app password if 2FA is on.
# MAIL_LIVE_PASSWORD=your-outlook-app-password
#
# #7 rehome — Gmail app password for andrewnewton965@gmail.com (the native IMAP
# fetcher, replacing the RRTS n8n Gmail workflow). Generate at
# https://myaccount.google.com/apppasswords (requires 2FA). 16 chars, no spaces.
# Referenced by config.yaml mail.accounts[gmail].password. The fetch loop is
# INERT (mail.fetch.enabled: false) until the operator flips, so this is only
# READ once the rehome is enabled on the box.
# GMAIL_ANDREWNEWTON965_APP_PASSWORD=your-gmail-app-password
