# Universal per-instance Alfred scaffold
#
# This is the universal per-instance scaffold. It ships the subordinate-
# default shape (KAL-LE-style: coding/clinic/etc. with talker +
# transport + instructor, but no primary-owner tools like curator /
# janitor / distiller / surveyor / mail). Optional blocks at the
# bottom of this file are commented out — uncomment what the new
# instance needs.
#
# Typical shapes:
#   Subordinate (KAL-LE, STAY-C): the default — no optional blocks
#     uncommented.
#   Hybrid (subordinate + own email pipeline): uncomment email_classifier
#     and ship a `mail` block (see config.yaml.example).
#   Primary-like (full Salem-shape): see config.yaml.example instead —
#     that template has curator/janitor/distiller/surveyor/mail.
#
# Historical note: filename used to be config.kalle.yaml.example. Renamed
# to config.instance.yaml.example once it became the universal scaffold.
#
# Ship one of these per multi-instance deployment. Salem stays on
# config.yaml; subordinates use this file (or the template `alfred
# instance new <name>` scaffolds from it).
#
# Run KAL-LE with:
#   source /home/andrew/.alfred/kalle/.venv/bin/activate
#   alfred --config config.kalle.yaml up --only talker,transport,instructor
#
# Required environment variables (add to ~/alfred/.env):
#   TELEGRAM_KALLE_BOT_TOKEN       — from @BotFather for KAL-LE's own bot
#   ALFRED_KALLE_TRANSPORT_TOKEN   — shared secret for KAL-LE's inbound transport
#   ALFRED_KALLE_PEER_TOKEN        — token Salem uses when reaching KAL-LE
#   ALFRED_SALEM_PEER_TOKEN        — token KAL-LE uses when reaching Salem
#   ANTHROPIC_API_KEY              — same as Salem's; can split later
#   GROQ_API_KEY                   — same as Salem's (STT)
# Generate each token with: python -c 'import secrets; print(secrets.token_hex(32))'

# ---------------------------------------------------------------------------
# Per-instance paths
# ---------------------------------------------------------------------------
daemon:
  # KAL-LE's PID file lives under /home/andrew/.alfred/kalle/ so it
  # doesn't collide with Salem's ./data/alfred.pid.
  pid_path: "/home/andrew/.alfred/kalle/data/alfred.pid"

# ---------------------------------------------------------------------------
# Vault — aftermath-lab is KAL-LE's primary
# ---------------------------------------------------------------------------
vault:
  path: "/home/andrew/aftermath-lab"
  # Two semantically distinct exclusion fields (see config.yaml.example
  # for the full rationale + the 2026-05-01 split):
  # - ``dont_scan_dirs`` — outbound issue scanning exclusion (replaces
  #   legacy ``ignore_dirs`` — same meaning).
  # - ``dont_index_dirs`` — valid-link-target index exclusion. Default
  #   empty: any record is a valid wikilink target.
  dont_scan_dirs: ["_templates", "_bases", "_docs", ".obsidian", "view", "session", "inbox"]
  dont_index_dirs: []
  ignore_files: [".gitkeep"]

# ---------------------------------------------------------------------------
# Logging — separate from Salem's
# ---------------------------------------------------------------------------
logging:
  level: "INFO"
  dir: "/home/andrew/.alfred/kalle/data"

# ---------------------------------------------------------------------------
# Transport — port 8892 (Salem=8891, STAY-C=8893, slot4=8894, slot5=8895)
# ---------------------------------------------------------------------------
transport:
  server:
    host: "127.0.0.1"
    port: 8892
  scheduler:
    poll_interval_seconds: 30
    stale_reminder_max_minutes: 180
  # Inbound auth — who can POST to KAL-LE's transport.
  auth:
    tokens:
      local:
        token: "${ALFRED_KALLE_TRANSPORT_TOKEN}"
        # Add `cli` if this instance uses transport from CLI handlers
        # (e.g. `alfred send ...`). Add `daily_sync` if the optional
        # daily_sync block below is uncommented.
        allowed_clients: [scheduler, brief, janitor, curator, talker]
      # Salem's peer entry — its identity when it reaches KAL-LE.
      salem:
        token: "${ALFRED_KALLE_PEER_TOKEN}"
        allowed_clients: [salem]
  # Outbound peers — where KAL-LE can reach.
  peers:
    salem:
      base_url: "http://127.0.0.1:8891"
      token: "${ALFRED_SALEM_PEER_TOKEN}"
  # Canonical — KAL-LE is NOT the owner (Salem holds canonical records).
  canonical:
    owner: false
    audit_log_path: "/home/andrew/.alfred/kalle/data/canonical_audit.jsonl"
    peer_permissions: {}
  state:
    path: "/home/andrew/.alfred/kalle/data/transport_state.json"
    dead_letter_max_age_days: 30

# ---------------------------------------------------------------------------
# Instructor — enables natural-language self-improvement directives
# ---------------------------------------------------------------------------
instructor:
  poll_interval_seconds: 60
  max_retries: 3
  audit_window_size: 5
  anthropic:
    api_key: "${ANTHROPIC_API_KEY}"
    model: "claude-sonnet-4-6"
    max_tokens: 4096
  state:
    path: "/home/andrew/.alfred/kalle/data/instructor_state.json"

# ---------------------------------------------------------------------------
# Talker — KAL-LE's Telegram bot, Opus default, longer session gap
# ---------------------------------------------------------------------------
telegram:
  bot_token: "${TELEGRAM_KALLE_BOT_TOKEN}"
  # Andrew's Telegram user_id (same as Salem's allowlist).
  allowed_users: []
  primary_users:
    - "person/Andrew Newton"
  # Instance identity — loaded into SKILL.md templating.
  instance:
    name: "KAL-LE"
    canonical: "K.A.L.L.E."
    aliases: ["Kali", "Callie", "Kallie"]
    skill_bundle: "vault-kalle"
    tool_set: "kalle"
  anthropic:
    api_key: "${ANTHROPIC_API_KEY}"
    # Opus for coding — reasoning depth matters.
    model: "claude-opus-4-7"
    max_tokens: 4096
    # Opus 4.x rejects temperature; conversation.py already drops it
    # for opus models, but keep the default sane for any code path
    # that reads it.
    temperature: 0.7
  stt:
    provider: "groq"
    api_key: "${GROQ_API_KEY}"
    model: "whisper-large-v3"
  # No tts on KAL-LE — no /brief, and we don't want audio replies for
  # coding work. Leaving this block absent means /brief replies "not
  # configured" if Andrew accidentally triggers it.
  session:
    # Coding sessions sprawl — 2hr vs Salem's 30min default.
    gap_timeout_seconds: 7200
    state_path: "/home/andrew/.alfred/kalle/data/talker_state.json"
  # Safety-critical bash_exec audit log — separate from Salem's.
  bash_exec:
    audit_path: "/home/andrew/.alfred/kalle/data/bash_exec.jsonl"

# ---------------------------------------------------------------------------
# Brief-digest pusher — V.E.R.A. content arc sender
# ---------------------------------------------------------------------------
# KAL-LE assembles a one-slide digest of yesterday's activity each
# morning and pushes it to Salem's /peer/brief_digest endpoint, where
# it lands in the 06:00 morning brief as the "### KAL-LE Update"
# section. Fires at 05:30 ADT — 30 minutes ahead of Salem's brief so
# the digest is always present when the brief assembles.
#
# Salem omits this block (Salem is the receiver, not a sender).
# STAY-C will adopt the same shape with self_name=stay-c.
brief_digest_push:
  enabled: true
  self_name: "kal-le"
  target_peer: "salem"
  schedule:
    time: "05:30"
    timezone: "America/Halifax"
  # Repos KAL-LE scans for yesterday's commits. Add new aftermath-*
  # repos here as they spin up.
  repo_paths:
    - "/home/andrew/aftermath-lab"
    - "/home/andrew/aftermath-alfred"
  # data_dir defaults to logging.dir when omitted; bash_exec.jsonl +
  # instructor_state.json live there.
  # bit_state_path is optional — KAL-LE doesn't run BIT in v1, so
  # leaving this empty defaults posture to "green / no BIT data".

# ===========================================================================
# OPTIONAL BLOCKS — uncomment what this instance needs.
# ===========================================================================
# The blocks below are intentionally commented out. Each is independent
# and has a short "uncomment if…" note. Remove the leading `# ` on every
# line of a block (including its header) to enable it.

# ---------------------------------------------------------------------------
# email_classifier — per-instance email triage cues
# ---------------------------------------------------------------------------
# Uncomment if this instance ingests email. Requires a `mail` block too
# (see config.yaml.example for the shape). Cue groups are per-instance:
# Salem's cues are Andrew-facing; a clinic instance would seed clinical
# signals instead.
#
# email_classifier:
#   enabled: true
#   anthropic:
#     api_key: "${ANTHROPIC_API_KEY}"
#     model: "claude-sonnet-4-6"
#     max_tokens: 1024
#     timeout_seconds: 60
#   prompt:
#     high:
#       - "From a named person this instance has interacted with recently"
#       - "Explicit time-pressure language (\"today\", \"by EOD\", \"urgent\", deadline within 48h)"
#       - "Reply-required signals (direct question, RSVP request)"
#     medium:
#       - "Appointments / confirmations / notices with future dates"
#       - "Subscription renewals"
#       - "Financial notifications (transactions, statements)"
#     low:
#       - "Newsletters the user chose to receive"
#       - "Marketing from established relationships (vendors)"
#       - "Automated notifications (system status, build emails, etc.)"
#     spam:
#       - "Unsolicited commercial"
#       - "Phishing-shape messages"
#       - "Unknown senders pitching products / services"
#   state:
#     path: "/home/andrew/.alfred/kalle/data/email_classifier_state.json"
#   named_contact_cache_seconds: 60
#   unclassified_sentinel: "unclassified"
#   # Point at the same file as daily_sync.corpus.path so the calibration
#   # loop writes and the classifier reads the same JSONL.
#   calibration_corpus_path: "/home/andrew/.alfred/kalle/data/email_calibration.jsonl"
#   calibration_few_shot_count: 10

# ---------------------------------------------------------------------------
# daily_sync — 09:00 OODA calibration loop
# ---------------------------------------------------------------------------
# Uncomment for a per-instance 09:00 calibration conversation over Telegram.
# Surfaces email-classifier items (and future signals) so Andrew can
# correct them; corrections feed back into the classifier few-shot
# corpus. Requires email_classifier above to be uncommented for the
# email tier.
# Also add `daily_sync` to transport.auth.tokens.local.allowed_clients.
#
# daily_sync:
#   enabled: true
#   schedule:
#     time: "09:00"
#     timezone: "America/Halifax"
#   batch_size: 5
#   corpus:
#     # Must match email_classifier.calibration_corpus_path above.
#     path: "/home/andrew/.alfred/kalle/data/email_calibration.jsonl"
#   confidence:
#     # Per-tier surfacing flags. Flipped by Telegram /calibration_ok <tier>.
#     high: false
#     medium: false
#     low: false
#     spam: false
#   state:
#     path: "/home/andrew/.alfred/kalle/data/daily_sync_state.json"

# ---------------------------------------------------------------------------
# brief.peer_digests — receive digest pushes from peers
# ---------------------------------------------------------------------------
# Uncomment if this instance RECEIVES peer digests (it is a primary-like
# aggregator, e.g. Salem). Each configured peer must also appear in
# transport.peers above, and each expected peer must match the
# self_name the peer sends in its brief_digest_push block.
#
# Note: this is NOT the full Salem brief block (weather, schedule,
# upcoming events). Subordinate instances that just want to receive a
# peer digest into their own brief would uncomment this sub-block only;
# full-brief shape lives in config.yaml.example.
#
# brief:
#   peer_digests:
#     enabled: true
#     expected_peers:
#       - kal-le

# ---------------------------------------------------------------------------
# digest — KAL-LE weekly cross-arc synthesis
# ---------------------------------------------------------------------------
# Uncomment to fire a weekly digest into ~/aftermath-lab/digests/. Off
# by default — only KAL-LE-shape instances that own the cross-arc
# review surface should enable this.
#
# digest:
#   enabled: true
#   schedule:
#     time: "07:00"
#     timezone: "America/Halifax"
#     day_of_week: "sunday"
#   output_dir: "/home/andrew/aftermath-lab/digests"
#   window_days: 7
#   # synthesis_vault is REQUIRED for section 4 ("Cross-arc patterns")
#   # to populate. Defaults to "" (ranker disabled, empty-state line
#   # rendered) — every instance must opt in explicitly so subordinate
#   # instances don't silently inherit another instance's vault.
#   synthesis_vault: "/home/andrew/aftermath-lab"
#   synthesis_top_n: 12

# ---------------------------------------------------------------------------
# kalle.projects — project name → vault path map (used by reviews + digest)
# ---------------------------------------------------------------------------
# Defaults (no override needed when these match):
#   aftermath-lab → ~/aftermath-lab
#   alfred        → ~/aftermath-alfred
#   rrts          → ~/aftermath-rrts
#
# kalle:
#   projects:
#     aftermath-lab: "/home/andrew/aftermath-lab"
#     alfred:        "/home/andrew/aftermath-alfred"
#     rrts:          "/home/andrew/aftermath-rrts"
