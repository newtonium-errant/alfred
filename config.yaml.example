vault:
  path: "./vault"
  ignore_dirs: ["_templates", "_bases", "_docs", ".obsidian", "view", "session", "inbox"]
  ignore_files: [".gitkeep"]

agent:
  backend: "claude"
  claude:
    command: "claude"
    args: ["-p"]
    timeout: 600
    allowed_tools: ["Bash"]
  zo:
    url: "https://api.zo.computer/zo/ask"
    method: "POST"
    headers:
      Authorization: "Bearer ${ZO_API_KEY}"
    request_body_template:
      message: "{prompt}"
    response_content_path: "response.content"
    timeout: 600
  openclaw:
    command: "openclaw"
    args: []
    workspace_mount: ""
    timeout: 600

logging:
  level: "INFO"
  dir: "./data"

curator:
  inbox_dir: "inbox"
  processed_dir: "inbox/processed"
  watcher:
    poll_interval: 5
    debounce_seconds: 10
  state:
    path: "./data/curator_state.json"

janitor:
  sweep:
    interval_seconds: 3600
    # Deep sweep is LLM-heavy — runs overnight so it doesn't collide
    # with the user's working hours. 02:30 America/Halifax daily by
    # default. Add ``day_of_week: sunday`` etc. for a weekly gate, or
    # omit the block entirely to fall back to deep_sweep_interval_hours.
    deep_sweep_schedule:
      time: "02:30"
      timezone: "America/Halifax"
    structural_only: false
    stub_body_threshold_chars: 50
    orphan_exempt_dirs: ["view"]
    max_files_per_agent_call: 30
    fix_log_in_vault: true
  state:
    path: "./data/janitor_state.json"
    max_sweep_history: 20

distiller:
  extraction:
    interval_seconds: 3600
    deep_interval_hours: 24
    candidate_threshold: 0.3
    max_sources_per_batch: 20
    source_types: ["conversation", "session", "note", "task", "project"]
    learn_types: ["assumption", "decision", "constraint", "contradiction", "synthesis"]
  state:
    path: "./data/distiller_state.json"
    max_run_history: 20

# Instructor — polls every vault record for pending ``alfred_instructions``
# directives and executes them in-process via the Anthropic SDK. See
# src/alfred/instructor/ for the daemon + CLI + SKILL.
instructor:
  poll_interval_seconds: 60
  max_retries: 3
  audit_window_size: 5
  anthropic:
    api_key: "${ANTHROPIC_API_KEY}"
    model: "claude-sonnet-4-6"
    max_tokens: 4096
  state:
    path: "./data/instructor_state.json"

# Outbound-push transport — HTTP server hosted inside the talker daemon
# that other tools POST to when they need to deliver a message to the
# user via Telegram. First consumers: ``remind_at`` reminders on tasks
# (scheduler client) + brief auto-push. See
# ``src/alfred/transport/__init__.py`` and the ratified plan in
# ``memory/project_outbound_transport.md``.
#
# Stage 3.5 extension: this same server hosts ``/peer/*`` and
# ``/canonical/*`` routes for cross-instance messaging — today those
# return 501 ``peer_not_implemented``. The ``auth.tokens`` dict is
# keyed by peer name for the same reason (Stage 3.5 adds ``kal-le`` /
# ``stay-c`` entries alongside ``local``).
#
# Generate a token with: python -c 'import secrets; print(secrets.token_hex(32))'
# Or run: alfred transport rotate
transport:
  server:
    host: "127.0.0.1"
    port: 8891
  scheduler:
    poll_interval_seconds: 30
    stale_reminder_max_minutes: 180
  auth:
    tokens:
      local:
        token: "${ALFRED_TRANSPORT_TOKEN}"
        allowed_clients:
          - scheduler
          - brief
          - janitor
          - curator
          - talker
  state:
    path: "./data/transport_state.json"
    dead_letter_max_age_days: 30

telegram:
  # Telegram bot token from @BotFather
  bot_token: "${TELEGRAM_BOT_TOKEN}"
  # Whitelist of Telegram user IDs allowed to talk to this bot.
  # Single-user wk1: your own Telegram user ID only.
  allowed_users: []
  # Which person/ records the talker treats as primary-user calibration
  # targets. Single-user wk1: just the vault owner.
  primary_users:
    - "person/Andrew Newton"
  # Per-instance persona identity. The talker's SKILL.md is templated
  # at load time — ``{{instance_name}}`` becomes casual greetings and
  # ``{{instance_canonical}}`` becomes the formal identity line. Fresh
  # installs get the neutral "Alfred" default; multi-instance deployments
  # (e.g. Salem / STAY-C / KAL-LE) override this per instance.
  # ``aliases`` is reserved for the multi-instance router so phone
  # autocorrect / voice transcription variants still route correctly
  # (unused today).
  instance:
    name: "Alfred"
    canonical: "Alfred"
    aliases: []
  anthropic:
    api_key: "${ANTHROPIC_API_KEY}"
    model: "claude-sonnet-4-6"
    max_tokens: 4096
    temperature: 0.7
  stt:
    provider: "groq"
    api_key: "${GROQ_API_KEY}"
    model: "whisper-large-v3"
  # wk2b: opt-in text-to-speech for /brief command. If this section is
  # absent, /brief replies "not configured". Default voice is "Rachel"
  # (ElevenLabs library default); model is Turbo v2.5 for low latency.
  # tts:
  #   provider: "elevenlabs"
  #   api_key: "${ELEVENLABS_API_KEY}"
  #   model: "eleven_turbo_v2_5"
  #   voice_id: "Rachel"
  #   summary_word_target: 300
  session:
    # Implicit session-end gap: 30 minutes of silence closes the session.
    gap_timeout_seconds: 1800
    state_path: "./data/talker_state.json"

# temporal:
#   address: "127.0.0.1:7233"
#   namespace: "default"
#   task_queue: "alfred-workflows"
#   workflow_dirs: ["./workflows"]
#   agents:
#     worker:
#       timeout: 300
#     vault-curator:
#       skill: vault-curator
#       scope: curator

bit:
  # BIT (built-in test) runs before the Morning Brief so the brief can
  # report on system health. By default it fires 5 minutes before
  # ``brief.schedule.time``; override with ``schedule.time: HH:MM``.
  # ``mode`` is ``quick`` (5s per tool) or ``full`` (15s per tool).
  schedule:
    # time: "05:55"          # explicit HH:MM; empty = derive from brief
    lead_minutes: 5          # subtract this from brief time
    # timezone: "America/Halifax"  # empty = use brief's timezone
    mode: "quick"
  output:
    directory: "process"
    name_template: "Alfred BIT {date}"
  state:
    path: "./data/bit_state.json"
    max_history: 30

surveyor:
  watcher:
    debounce_seconds: 30
  ollama:
    base_url: "http://localhost:11434"
    model: "nomic-embed-text"
    embedding_dims: 768
    # api_key: "${OPENROUTER_API_KEY}"  # If set, uses OpenAI-compatible /v1/embeddings endpoint
    # When using OpenRouter for embeddings, set:
    #   base_url: "https://openrouter.ai/api/v1"
    #   model: "openai/text-embedding-3-small"
    #   embedding_dims: 1536
    #   api_key: "${OPENROUTER_API_KEY}"
  milvus:
    uri: "./data/milvus_lite.db"
    collection_name: "vault_embeddings"
  clustering:
    hdbscan:
      min_cluster_size: 3
      min_samples: 2
    leiden:
      resolution: 1.0
  openrouter:
    api_key: "${OPENROUTER_API_KEY}"
    base_url: "https://openrouter.ai/api/v1"
    model: "x-ai/grok-4.1-fast"
    temperature: 0.3
  labeler:
    max_files_per_cluster_context: 20
    body_preview_chars: 200
    min_cluster_size_to_label: 2
    # Drop any LLM-suggested relationship whose confidence is below this gate.
    # Raised from the historical 0.5 default to filter out low-grounding guesses.
    min_relationship_confidence: 0.65
  state:
    path: "./data/surveyor_state.json"
