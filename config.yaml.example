# ---------------------------------------------------------------------------
# Multi-instance (Stage 3.5) setup
# ---------------------------------------------------------------------------
# Alfred is deployable as multiple independent instances on the same host
# — one ``config.yaml`` per instance, one ``alfred up`` per config.
# Instance identities are hard-coded in ``telegram.instance`` (below).
#
# Port convention (keep these unique per instance):
#   SALEM   → 8891  (ops / orchestrator)
#   KAL-LE  → 8892  (coding)
#   STAY-C  → 8893  (NP clinic, PHI-firewalled)
#   slot 4  → 8894  (reserved — RRTS or Knowledge)
#   slot 5  → 8895  (reserved)
#
# Per-instance config path convention:
#   config.yaml         — Salem (this file)
#   config.kalle.yaml   — KAL-LE (see config.kalle.yaml.example)
#   config.stayc.yaml   — STAY-C (future)
#
# The ``daemon.pid_path`` field below is what keeps ``alfred up``/``alfred
# down`` per-instance from colliding. Salem defaults to ``./data/alfred.pid``;
# KAL-LE overrides to ``/home/andrew/.alfred/kalle/data/alfred.pid``.
# daemon:
#   pid_path: "./data/alfred.pid"  # override in config.<instance>.yaml

# ---------------------------------------------------------------------------
# Runtime-location legend — where each config section actually EXECUTES
# ---------------------------------------------------------------------------
# Most top-level sections map 1:1 to a daemon with its own log file
# (data/<tool>.log). THREE DO NOT — they run inline inside a host
# daemon's process, so their log lines land in the HOST's file. Two
# real diagnosis incidents (2026-06-11) started as "subsystem X looks
# dead" when X was healthy and logging into its host's file:
#
#   email_classifier: → runs INSIDE curator (post-processor per inbox
#                       file) → logs to data/curator.log.
#                       data/email_classifier.log belongs to the
#                       standalone CLI backfill only.
#   gcal:             → runs INSIDE talker → logs to data/talker.log.
#   transport:        → the HTTP server is HOSTED by talker (no
#                       transport daemon) → logs to data/talker.log.
#
# The ``mail`` section's split, for the same reason:
#   mail (daemon slot) = the WEBHOOK receiver (live inbound path:
#                       n8n → tunnel → webhook → inbox) →
#                       data/mail_webhook.log.
#   IMAP fetcher       = manual CLI only (``alfred mail fetch``,
#                       deliberate fallback) → data/mail.log.
#
# alfred.log = orchestrator + captured child stdout only.

vault:
  path: "./vault"
  # Two semantically distinct exclusion fields (split 2026-05-01):
  #
  # ``dont_scan_dirs`` — directories whose records should NOT be scanned
  #   for issues by janitor/curator/distiller. Examples: ``view`` (Dataview
  #   base outputs), ``inbox`` (raw / processed email bodies), ``session``
  #   (voice transcripts that aren't validated as records).
  #
  # ``dont_index_dirs`` — directories whose records should NOT be valid
  #   wikilink targets in janitor's link-resolution index. Default
  #   empty: a record is a valid link target unless the operator
  #   explicitly opts out (e.g. archive/, deprecated/).
  #
  # Pre-2026-05-01 the two were conflated into a single ``ignore_dirs``
  # field, which silently flagged valid wikilinks to records under
  # ``session/`` as LINK001. The legacy key still works — set ONLY
  # ``ignore_dirs`` and it's treated as ``dont_scan_dirs`` (with
  # ``dont_index_dirs`` defaulting to empty, i.e. the bug fix).
  # Configs that set BOTH legacy + new should prefer the new keys —
  # ``dont_scan_dirs`` wins when both are present.
  # ``daily/`` is a derivative directory written by the routine daemon
  # at 05:59 Halifax; the brief reads it at 06:00. Skip it from janitor
  # scans — it's not user-authored content, it's a per-day aggregator
  # snapshot.
  dont_scan_dirs: ["_templates", "_bases", "_docs", ".obsidian", "view", "session", "inbox", "daily"]
  dont_index_dirs: []
  ignore_files: [".gitkeep"]

agent:
  # Backend selector. Post backend-abstraction-collapse (2026-05-25),
  # ``claude`` is the only supported value across curator / janitor /
  # distiller — anything else fails loud at daemon startup. Future
  # backends (Q3 MCP, local Ollama) extend the value set with a matching
  # sub-block here.
  backend: "claude"
  claude:
    command: "claude"
    args: ["-p"]
    timeout: 600
    allowed_tools: ["Bash"]

logging:
  level: "INFO"
  dir: "./data"
  # Size-based log rotation via Python's ``RotatingFileHandler``.
  # Every per-tool log file (``curator.log``, ``surveyor.log``, etc.)
  # is capped at ``max_bytes``; once the live file fills, it's rolled
  # to ``<tool>.log.1`` and a fresh file opens. Up to ``backup_count``
  # rotated copies are kept; older backups are deleted.
  #
  # Defaults: 100 MB x 5 backups = ~500 MB per tool, ~7.5 GB worst-case
  # across ~15 daemons. Without rotation, ``surveyor.log`` was observed
  # at 14 GB and ``alfred.log`` at 15 GB in routine operation (grep slow,
  # tail painful). Omit the block entirely to take the defaults.
  #
  # Escape hatch: set ``max_bytes: 0`` to disable rotation if you'd
  # rather manage rotation externally (logrotate, journald, etc.).
  #
  # Daemon-restart contract: rotation activates on next daemon startup.
  # An already-running daemon keeps its existing FileHandler (no
  # rotation) until restarted — ``alfred down && alfred up`` applies
  # the new rotation policy. Each daemon emits a one-shot
  # ``logging.rotation.policy_applied`` event at startup (grep
  # ``data/<tool>.log``) so you can confirm config was honored.
  rotation:
    max_bytes: 100000000  # 100 MB per file
    backup_count: 5

curator:
  inbox_dir: "inbox"
  processed_dir: "inbox/processed"
  watcher:
    poll_interval: 5
    debounce_seconds: 10
  state:
    path: "./data/curator_state.json"
  # Idle-tick heartbeat — emits a periodic ``curator.idle_tick`` log
  # event so operators can distinguish *idle / healthy* from *broken*.
  # Counter semantic: one inbox file processed end-to-end = one event
  # (see ``events_in_window`` in the emitted event). Defaults on; see
  # ``src/alfred/common/heartbeat.py`` for rationale. Flip ``enabled``
  # false to silence without restructuring config.
  idle_tick:
    enabled: true
    interval_seconds: 60

# Email classifier — per-instance priority + action-hint tagging on
# email-derived note records. Hooks into the curator daemon as a
# post-processor: after curation completes, every newly-created
# ``note/*.md`` derived from email-shaped inbox content gets two
# frontmatter fields written:
#   priority:    high | medium | low | spam | unclassified
#   action_hint: free-text recommendation (e.g. "calendar", "archive",
#                "ignore", "file:newsletter/Tim Denning") — RECOMMENDATION
#                ONLY, never auto-executed in c1.
#
# Per-instance design (Stage 3.5): this block is owned by Salem's
# config.yaml. STAY-C will get its own ``email_classifier:`` block in
# config.stayc.yaml when the instance is built (with clinical-urgency
# cues for Jamie, not Andrew's contact list). KAL-LE has no email
# pipeline so config.kalle.yaml deliberately omits the block.
#
# Set enabled: false to disable while keeping the rest of the config.
# Absent block ≡ enabled: false.
#
# Filed under ``email-surfacing c1`` of the multi-chunk arc; c2 ships
# the calibration loop (Daily Sync) that refines the cue lists below.
email_classifier:
  enabled: true
  anthropic:
    api_key: "${ANTHROPIC_API_KEY}"
    model: "claude-sonnet-4-6"
    max_tokens: 1024
    timeout_seconds: 60
  # Cue groups — the cold-prompt seed for Salem. Each list is bullets
  # the model treats as priority hints. Calibration in c2 grows these
  # lists over time; today they are static.
  prompt:
    high:
      - "From a named person Andrew has interacted with recently (vault-lookup for person records)"
      - "Explicit time-pressure language (\"today\", \"by EOD\", \"urgent\", deadline within 48h)"
      - "Reply-required signals (direct question to Andrew, RSVP request)"
      - "Jamie Newton's messages"
      - "RRTS customer messages"
    medium:
      - "Appointments / confirmations / notices with future dates"
      - "Subscription renewals"
      - "Financial notifications (transactions, statements)"
      - "Family mentions (Newton family members beyond Andrew/Jamie)"
    low:
      - "Newsletters Andrew chose to receive"
      - "Marketing from established relationships (vendors he uses)"
      - "Automated notifications (system status, build emails, etc.)"
    spam:
      - "Unsolicited commercial"
      - "Phishing-shape messages"
      - "Unknown senders pitching products / services"
  state:
    path: "./data/email_classifier_state.json"
  # Memoise the named-contact lookup for this many seconds during a
  # batch run. Single-file watcher pass: this never matters. Batch
  # runs over hundreds of files: avoids re-scanning person/ each time.
  named_contact_cache_seconds: 60
  # Frontmatter ``priority`` value written when the LLM call fails or
  # returns malformed JSON. Calibration in c2 picks records with this
  # value to re-classify. Keep stable — c2/c3 will look for it.
  unclassified_sentinel: "unclassified"
  # c2 Phase 1 corpus → classifier feedback. When this points at a
  # non-empty JSONL the classifier rotates the most recent N entries
  # into its system prompt as few-shot examples. Match the path to
  # ``daily_sync.corpus.path`` so Daily Sync writes and the classifier
  # reads the same file.
  calibration_corpus_path: "./data/email_calibration.salem.jsonl"
  calibration_few_shot_count: 10

janitor:
  sweep:
    interval_seconds: 3600
    # Deep sweep is LLM-heavy — runs overnight so it doesn't collide
    # with the user's working hours. 02:30 America/Halifax daily by
    # default. Add ``day_of_week: sunday`` etc. for a weekly gate, or
    # omit the block entirely to fall back to deep_sweep_interval_hours.
    deep_sweep_schedule:
      time: "02:30"
      timezone: "America/Halifax"
    structural_only: false
    stub_body_threshold_chars: 50
    orphan_exempt_dirs: ["view"]
    max_files_per_agent_call: 30
    fix_log_in_vault: true
  state:
    path: "./data/janitor_state.json"
    max_sweep_history: 20
  # Idle-tick heartbeat — counter semantic: one issue fixed (or deleted)
  # = one event. Sweeps that find nothing broken add zero to the
  # heartbeat, so the signal reflects meaningful work, not scan noise.
  # Defaults on; see ``src/alfred/common/heartbeat.py``.
  idle_tick:
    enabled: true
    interval_seconds: 60

distiller:
  extraction:
    interval_seconds: 3600
    # Deep extraction is LLM-heavy — runs overnight so it doesn't
    # collide with the user's working hours. 03:30 America/Halifax
    # daily by default, staggered ~1h after the janitor deep sweep.
    # Omit the block entirely to fall back to deep_interval_hours.
    deep_extraction_schedule:
      time: "03:30"
      timezone: "America/Halifax"
    # Weekly consolidation pass — Sundays at 04:00 Halifax. The
    # day_of_week key turns the ScheduleConfig into a weekly gate;
    # one of monday..sunday (case-insensitive). Omit the block to
    # fall back to consolidation_interval_hours.
    consolidation_schedule:
      time: "04:00"
      timezone: "America/Halifax"
      day_of_week: "sunday"
    candidate_threshold: 0.3
    max_sources_per_batch: 20
    source_types: ["conversation", "session", "note", "task", "project"]
    learn_types: ["assumption", "decision", "constraint", "contradiction", "synthesis"]
  state:
    path: "./data/distiller_state.json"
    max_run_history: 20
  # Idle-tick heartbeat — counter semantic: one learn record created =
  # one event. Defaults on; see ``src/alfred/common/heartbeat.py``.
  idle_tick:
    enabled: true
    interval_seconds: 60
  # Phase 4 embedding-pattern miner — KAL-LE distiller-radar consumer
  # of the surveyor's labeled-cluster output. Surfaces "unnamed
  # themes" (clusters that have cohered semantically but lack a
  # canonical artifact) as inbox proposals for new architecture/ or
  # principles/ records.
  #
  # See `project_kalle_phase4_pattern_miner.md` for the full design.
  # Block defaults to OFF (`enabled: false`); per-instance configs
  # opt in. Salem typically omits the block entirely; KAL-LE adds it.
  #
  # Run ad-hoc with:
  #   alfred --config <config> distiller mine-patterns [--dry-run]
  #     [--min-cluster-size N] [--top N]
  #
  # Drafter LLM endpoint reuses an OpenAI-compatible chat-completions
  # API. KAL-LE points it at its local Ollama (qwen2.5:14b at
  # 172.22.0.1:11434/v1) — no cloud cost. Empty base_url or model
  # triggers the safe-degraded path: proposals still write but with
  # a placeholder paragraph the operator fills in manually.
  #
  # pattern_miner:
  #   enabled: true
  #   surveyor_state_path: "./data/surveyor_state.json"
  #   proposed_dir: "inbox/proposed-canonical"
  #   min_cluster_size: 3
  #   canonical_match_dirs: ["architecture", "principles", "stack"]
  #   label_denylist:
  #     # Operator-extended; union'd with the module-level default.
  #     # Add labels surveyor sometimes emits that don't signal a
  #     # real theme (e.g. cohered on document-type rather than topic).
  #     # - "instance-specific-low-signal-label"
  #   # Stage 2e (2026-05-11) — semantic-dupe gate. Candidate clusters
  #   # whose member-set Jaccard similarity meets/exceeds this value
  #   # against any prior promoted/discarded entry are rejected as
  #   # semantic duplicates. Catches surveyor's habit of re-clustering
  #   # yesterday's promoted members under a new slug the LLM names
  #   # differently. Default 0.5; tune higher (0.7) for tighter
  #   # rejection or lower (0.3) for looser overlap.
  #   jaccard_threshold: 0.5
  #   state:
  #     path: "./data/pattern_miner_state.json"
  #   openrouter:
  #     api_key: "ollama"  # ignored by Ollama; any value works
  #     base_url: "http://172.22.0.1:11434/v1"
  #     model: "qwen2.5:14b"

# Instructor — polls every vault record for pending ``alfred_instructions``
# directives and executes them in-process via the Anthropic SDK. See
# src/alfred/instructor/ for the daemon + CLI + SKILL.
instructor:
  poll_interval_seconds: 60
  max_retries: 3
  audit_window_size: 5
  anthropic:
    api_key: "${ANTHROPIC_API_KEY}"
    model: "claude-sonnet-4-6"
    max_tokens: 4096
  state:
    path: "./data/instructor_state.json"
  # Idle-tick heartbeat — counter semantic: one directive executed =
  # one event. Poll ticks that find no pending work add zero, so the
  # signal reflects actual work, not poll noise. Defaults on; see
  # ``src/alfred/common/heartbeat.py``.
  idle_tick:
    enabled: true
    interval_seconds: 60

# Outbound-push transport — HTTP server hosted inside the talker daemon
# that other tools POST to when they need to deliver a message to the
# user via Telegram. First consumers: ``remind_at`` reminders on tasks
# (scheduler client) + brief auto-push. See
# ``src/alfred/transport/__init__.py`` and the ratified plan in
# ``memory/project_outbound_transport.md``.
#
# Stage 3.5 extension: this same server hosts ``/peer/*`` and
# ``/canonical/*`` routes for cross-instance messaging — today those
# return 501 ``peer_not_implemented``. The ``auth.tokens`` dict is
# keyed by peer name for the same reason (Stage 3.5 adds ``kal-le`` /
# ``stay-c`` entries alongside ``local``).
#
# Generate a token with: python -c 'import secrets; print(secrets.token_hex(32))'
# Or run: alfred transport rotate
transport:
  server:
    host: "127.0.0.1"
    port: 8891
  scheduler:
    poll_interval_seconds: 30
    stale_reminder_max_minutes: 180
  auth:
    tokens:
      local:
        token: "${ALFRED_TRANSPORT_TOKEN}"
        allowed_clients:
          - scheduler
          - brief
          - janitor
          - curator
          - talker
      # Web front-end (Frontend M1) — the Next BFF holds THIS dedicated
      # peer token (its own secret, never reusing ``local``) and presents
      # ``X-Alfred-Client: web``. This is Layer 1 ("this front-end may talk
      # to me"); the per-user X-Alfred-Session token (Layer 2) is verified
      # by the web handlers, not here. Only present on instances that enable
      # the ``web:`` block below.
      # web:
      #   token: "${ALFRED_WEB_PEER_TOKEN}"
      #   allowed_clients:
      #     - web
  state:
    path: "./data/transport_state.json"
    dead_letter_max_age_days: 30

  # Salem-only: per-peer canonical record permissions (Phase A inter-
  # instance comms). Each peer gets a per-record-type field allowlist.
  # Empty / missing peer = denied. Empty / missing fields within a
  # peer's type = denied. The propose flow's payload schema defines
  # what's writable; these allowlists govern READS only.
  #
  # Conservative defaults below; tighten / loosen per policy.
  # canonical:
  #   owner: true
  #   audit_log_path: "./data/canonical_audit.jsonl"
  #   proposals_path: "./data/canonical_proposals.jsonl"
  #
  #   # NL-lane broker (LLM-mediated opt-in lane, kind=query_nl) —
  #   # HOLDER-side master switch. Absent block = lane OFF (fail-closed).
  #   # The lane additionally requires per-(peer, type) `nl_query` grants
  #   # below — BOTH levels must opt in. The holder's LLM translates a
  #   # peer's natural-language question into structured queries (which
  #   # run through the SAME deterministic gates as /peer/search) and
  #   # composes a prose answer from policy-cleared fields only.
  #   # nl_broker:
  #   #   enabled: true
  #   #   model: ""                    # "" = inherit telegram.anthropic.model
  #   #   max_subqueries: 1            # sub-queries one question may derive
  #   #   question_max_chars: 2000     # inbound NL question size gate
  #   #   max_answer_chars: 1200       # composed answer hard cap (truncates)
  #   #   verbatim_run_limit: 80       # compose-tier verbatim-dump guard
  #   #   compose_field_max_chars: 1500  # per-value cap into the composer
  #   #   interpret_max_tokens: 1024
  #   #   compose_max_tokens: 1024
  #   #   llm_timeout_seconds: 30
  #
  #   peer_permissions:
  #     kal-le:
  #       person:   { fields: [name, email, timezone, aliases, preferences.coding] }
  #       project:  { fields: [name, status, description] }
  #       org:      { fields: [name, type, status, alfred_tags] }
  #       location: { fields: [name, type, address, alfred_tags] }
  #       event:    { fields: [name, type, title, start, end, status, alfred_tags] }
  #     hypatia:
  #       person:   { fields: [name, email, timezone, aliases] }
  #       project:  { fields: [name, status, description] }
  #       org:      { fields: [name, type, status, alfred_tags] }
  #       location: { fields: [name, type, address, alfred_tags] }
  #       event:
  #         fields: [name, type, title, start, end, status, alfred_tags]
  #         # Deterministic filtered-query opt-in (P1) — governs
  #         # /peer/search + the async kind=query broker. Absent = denied.
  #         # query:
  #         #   filter_dims:
  #         #     participants: { op: [eq, contains] }
  #         #     date: { op: [gte, lte, between] }
  #         #   sort: [date]
  #         #   max_limit: 10
  #         #   default_limit: 5
  #         # NL-lane opt-in for THIS peer × type (requires the `query`
  #         # block above AND canonical.nl_broker.enabled). Absent = the
  #         # NL lane is denied for this pair.
  #         #
  #         # compose_fields is the COMPOSITION-GRANT tier: fields the
  #         # composer may READ to inform its prose answer but which are
  #         # never raw-released through any lane. GOVERNANCE: a
  #         # compose-grant is a disclosure decision with friction — the
  #         # peer can learn what the field says in PARAPHRASE. Only
  #         # compose-grant a field whose content is acceptable for that
  #         # peer to learn in prose. Ships EMPTY by default.
  #         # nl_query:
  #         #   compose_fields: []     # e.g. [description]
  #         #   max_records: 5         # records fed to the composer

# ---------------------------------------------------------------------------
# Google Calendar integration (Phase A+ inter-instance comms — Salem-only)
# ---------------------------------------------------------------------------
# When enabled on the canonical-owning instance (Salem), the
# /canonical/event/propose-create handler queries:
#   * Alfred Calendar (R/W) — a dedicated Google Calendar Salem writes to
#   * Primary calendar (R/O by application policy) — Andrew's own meetings
# for conflict-check, then pushes accepted events to the Alfred Calendar
# so they land on Andrew's phone.
#
# Default: disabled. Hypatia / KAL-LE leave this block out (or
# enabled: false) so they never try to talk to Google.
#
# Operator setup (one-time):
#   1. In Google Cloud Console: create a "Desktop app" OAuth 2.0 Client
#      ID. Download credentials.json, save to credentials_path below.
#   2. Create a dedicated "Alfred" calendar on your Google account.
#      Note its Calendar ID (Settings → Integrate calendar → Calendar ID).
#   3. Note your primary calendar ID too (usually your email address).
#   4. Set ALFRED_GCAL_CALENDAR_ID + ALFRED_GCAL_PRIMARY_ID in .env.
#   5. Run `alfred gcal authorize` — opens browser for consent.
#   6. Run `alfred gcal status` to confirm wiring.
#   7. Run `alfred gcal test-write` to validate end-to-end.
# gcal:
#   enabled: false
#   credentials_path: "~/alfred/data/secrets/gcal_credentials.json"
#   token_path: "~/alfred/data/secrets/gcal_token.json"
#   alfred_calendar_id: "${ALFRED_GCAL_CALENDAR_ID}"
#   primary_calendar_id: "${ALFRED_GCAL_PRIMARY_ID}"
#   scopes:
#     - "https://www.googleapis.com/auth/calendar.events"
#   # Per-instance label for the writable calendar. Surfaces as the
#   # ``gcal_calendar`` value in vault frontmatter + create-event response.
#   # Salem ships ``"alfred"``; V.E.R.A. would set ``"rrts"``; STAY-C
#   # client cal would set ``"stayc"``. Descriptive metadata only — the
#   # actual write target is always ``alfred_calendar_id``.
#   alfred_calendar_label: "alfred"
#   # Optional IANA timezone name (e.g. "America/Halifax"). When set,
#   # passed to GCal create-event so display semantics match Andrew's
#   # local time. When empty (default), GCal uses the calendar's own
#   # default zone for display — actual time is unambiguous either way.
#   default_time_zone: ""
#   # Future: V.E.R.A. (RRTS calendar) and STAY-C (client calendar) will
#   # each define their own gcal block in their own config.<instance>.yaml.

# --- Web front-end (Frontend M1) -------------------------------------------
# A browser chat with this instance, vault-grounded and scope-enforced,
# sharing the EXACT ``run_turn`` engine the Telegram talker uses. The routes
# mount on the existing transport server (no second port). DISABLED by
# default — an absent or ``enabled: false`` block mounts NO web routes and
# leaves the transport server byte-unchanged (opt-in; M1 targets Salem only).
#
# Requires a dedicated ``transport.auth.tokens.web`` peer entry above (the
# BFF's Layer-1 token). Magic-link login emails via Resend.
#
# web:
#   enabled: true
#   # Single-use magic-link nonce store (tool-scoped default shown).
#   state_path: "./data/web_auth_state.json"
#   # The named-user allowlist — this IS the user table (no DB). Each entry's
#   # ``name`` is the stable handle (→ a reserved synthetic session id);
#   # ``role`` maps to the existing run_turn scope rail (owner / ops);
#   # ``email`` is the magic-link delivery address (Sub-arc B).
#   users:
#     - { name: andrew, role: owner, email: "you@example.com" }
#     # - { name: ben,  role: ops,   email: "ben@example.com" }
#   auth:
#     # Instance HMAC signing secret for session + magic-link tokens
#     # (Sub-arc B). Fails loud at the auth-use site if web is enabled and
#     # this is empty — never sign with an empty key.
#     session_secret: "${ALFRED_WEB_SESSION_SECRET}"
#     session_ttl_hours: 168          # 7-day session token lifetime
#     magic_link_ttl_minutes: 15      # short-lived, single-use login link
#     base_url: "${ALFRED_WEB_BASE_URL}"   # public origin (cloudflared subdomain)
#   email:
#     provider: resend
#     api_key: "${RESEND_API_KEY}"
#     from_address: "${ALFRED_WEB_FROM_ADDRESS}"

telegram:
  # Telegram bot token from @BotFather
  bot_token: "${TELEGRAM_BOT_TOKEN}"
  # Whitelist of Telegram user IDs allowed to talk to this bot.
  # Single-user wk1: your own Telegram user ID only.
  allowed_users: []
  # Which person/ records the talker treats as primary-user calibration
  # targets. Single-user wk1: just the vault owner.
  primary_users:
    - "person/Andrew Newton"
  # Per-instance persona identity. The talker's SKILL.md is templated
  # at load time — ``{{instance_name}}`` becomes casual greetings and
  # ``{{instance_canonical}}`` becomes the formal identity line.
  # ``name`` is REQUIRED — "Alfred" is the project / architecture name,
  # never an instance name. Pick the instance identity for this deploy
  # (Salem / KAL-LE / Hypatia / etc.). Config without ``instance.name``
  # fails to load with a clear ``TypeError``.
  # ``aliases`` is the multi-instance router's accept list so phone
  # autocorrect / voice-transcription variants still route correctly
  # ("Salem" → S.A.L.E.M., "Pat" → Hypatia).
  instance:
    name: "Salem"
    canonical: "S.A.L.E.M."
    aliases:
      - "Salem"
    # Stage 3.5: which SKILL bundle to load at startup. Salem keeps the
    # default ``vault-talker``; KAL-LE overrides to ``vault-kalle`` in
    # ``config.kalle.yaml``. The bundle resolves to
    # ``src/alfred/_bundled/skills/<skill_bundle>/SKILL.md``.
    skill_bundle: "vault-talker"
    # Which vault-bridge tool set to expose to the model. ``talker``
    # (default) = vault_* only. ``kalle`` = vault_* + bash_exec for the
    # coding instance.
    tool_set: "talker"
  anthropic:
    api_key: "${ANTHROPIC_API_KEY}"
    model: "claude-sonnet-4-6"
    max_tokens: 4096
    temperature: 0.7
  stt:
    provider: "groq"
    api_key: "${GROQ_API_KEY}"
    model: "whisper-large-v3"
  # wk2b: opt-in text-to-speech for /brief command. If this section is
  # absent, /brief replies "not configured". Default voice is "Rachel"
  # (ElevenLabs library default); model is Turbo v2.5 for low latency.
  # tts:
  #   provider: "elevenlabs"
  #   api_key: "${ELEVENLABS_API_KEY}"
  #   model: "eleven_turbo_v2_5"
  #   voice_id: "Rachel"
  #   summary_word_target: 300
  session:
    # Implicit session-end gap: 30 minutes of silence closes the session.
    gap_timeout_seconds: 1800
    state_path: "./data/talker_state.json"
    # Per-instance opt-in: when true, the post-close hook runs an LLM
    # call to derive a 3-5 word topic slug from session content and
    # renames the session record file. Default false (Salem/KAL-LE
    # style: opening-message slug). Hypatia-style instances should
    # enable this for substantive-filename navigation.
    derive_slug_from_substance: false
  # Idle-tick heartbeat — emits a periodic ``talker.idle_tick`` log event
  # so an operator scanning the tail of ``data/talker.log`` can distinguish
  # *idle / healthy* (recent heartbeat present, low or zero
  # ``inbound_in_window``) from *broken* (no heartbeat at all). Defaults
  # are conservative-on; flip ``enabled`` to false to silence the
  # heartbeat without restructuring config. See
  # ``src/alfred/common/heartbeat.py`` for cadence rationale (60s ≈ 290
  # KB/day vs 1Hz ≈ 17 MB/day for no extra diagnostic value). Sibling
  # ``idle_tick:`` blocks live under curator/janitor/distiller/surveyor/
  # instructor/mail — same shape, same defaults; brief/bit/daily_sync
  # are deliberately excluded (clock-aligned scheduled fires, the wake
  # event itself is the natural positive signal).
  idle_tick:
    enabled: true
    interval_seconds: 60

# temporal:
#   address: "127.0.0.1:7233"
#   namespace: "default"
#   task_queue: "alfred-workflows"
#   workflow_dirs: ["./workflows"]
#   agents:
#     worker:
#       timeout: 300
#     vault-curator:
#       skill: vault-curator
#       scope: curator

# Morning Brief — daily operational briefing assembled into the vault.
# Schedule / weather / output knobs all default sensibly via dataclass
# defaults; add a ``brief:`` section only when you need to override.
# The block below shows the Phase 1 Upcoming Events sub-config.
brief:
  # schedule: { time: "06:00", timezone: "America/Halifax" }
  # weather: { stations: [...] }
  # output: { directory: "run", name_template: "Morning Brief {date}" }
  #
  # Upcoming Events — forward-looking calendar slice. Scans event
  # records (frontmatter ``date``) and task records (frontmatter
  # ``due``), buckets them as Today / This Week / Later, drops anything
  # past ``max_days_ahead``. Filter rules will grow inline in
  # upcoming_events.py as real-data patterns reveal what counts as noise.
  upcoming_events:
    enabled: true            # set false to omit the section entirely
    max_days_ahead: 30       # window cap; events further out are dropped
  #
  # Peer Digests — V.E.R.A. content arc receiver. Each specialist
  # instance (KAL-LE, STAY-C, ...) pushes its own one-slide digest to
  # this principal's /peer/brief_digest endpoint each morning. The
  # brief renders one ``### {Peer} Update`` sub-section per peer.
  # When a peer in ``expected_peers`` didn't push today, the section
  # falls back to "No {Peer} update today." so absence is visible.
  peer_digests:
    enabled: true            # set false to omit the section entirely
    expected_peers:          # peers whose absence should surface
      - kal-le
    # peer_canonical_names: # optional override for the section header
    #   kalle: "K.A.L.L.E."  # default uppercases the peer key
  #
  # Watch Items — config-driven upstream checks the brief runs LIVE
  # each morning (unauthenticated GitHub REST; 60 req/hr unauth is
  # plenty at one brief/day). Absent list = feature off, section never
  # rendered. Render contract: stable state = quiet one-liner;
  # state-flip since the last brief = loud 🚨 line carrying your
  # on_flip_note; a flipped-to-terminal item keeps a "✓ done — remove
  # from config when acted on" line every brief until YOU remove it
  # (operator-in-the-loop — nothing auto-removes). A failing check
  # renders "watch unavailable (api error: ...)" and never kills the
  # brief. Last-seen state: ./data/brief_watches_state.json (keyed by
  # ``id`` — keep ids stable once set).
  #
  # Two types:
  #   github_pr              — repo + number; open / merged / closed.
  #   github_release_mention — repo + pattern (regex, case-insensitive,
  #                            matched across tag+name+body) +
  #                            baseline_tag (only releases STRICTLY
  #                            newer than this are scanned).
  #
  # baseline_tag must be the EXACT tag string of the repo's current
  # latest release at the time you add the watch (including any "v"
  # prefix) — the boundary is matched by tag equality against the
  # newest-releases page, so a baseline that isn't on that page makes
  # all 20 newest releases candidates on the first check.
  #
  # Example (the North Mini Code spike watches, 2026-06-11):
  # watches:
  #   - id: llamacpp-cohere2moe-pr
  #     label: "llama.cpp cohere2moe arch"
  #     type: github_pr
  #     repo: "ggml-org/llama.cpp"
  #     number: 24260
  #     on_flip_note: "NMC GGUF unblocked — rebuild llama.cpp + retry the spike (project_nmc_spike.md)"
  #   - id: ollama-vendors-cohere2moe
  #     label: "ollama release vendoring cohere2moe"
  #     type: github_release_mention
  #     repo: "ollama/ollama"
  #     pattern: "cohere2moe|north.?mini"
  #     baseline_tag: "v0.30.7"
  #     on_flip_note: "ollama can serve NMC natively — swap the spike to ollama pull (project_nmc_spike.md)"

# Daily Sync — 09:00 ADT Telegram conversation channel (email-surfacing c2).
# Salem fires a per-day OODA-loop message: today's calibration batch (5
# email-classifier items by default) plus future friction-queue and
# open-question sections. Andrew replies in terse forms ("✅",
# "2 down, 4 spam", "2: actually high — Jamie was waiting"); the parser
# routes corrections into the per-instance calibration corpus.
#
# Per-instance (Stage 3.5): Salem's block lives here. STAY-C will get
# its own ``daily_sync:`` block in config.stayc.yaml when Jamie's
# clinical instance is built. KAL-LE intentionally omits the block —
# coding work doesn't need a 09:00 conversation channel.
#
# Set enabled: false to disable while keeping the rest of the config.
# Absent block ≡ enabled: false.
daily_sync:
  enabled: true
  schedule:
    time: "09:00"
    timezone: "America/Halifax"
  # How many email-classifier items to surface per fire. The framework
  # will accommodate other section providers (friction, questions) in
  # future chunks; this knob only affects the email section.
  batch_size: 5
  corpus:
    # Per-instance calibration corpus (append-only JSONL). The
    # classifier reads the tail for few-shot rotation; Daily Sync
    # writes here when Andrew replies.
    path: "./data/email_calibration.salem.jsonl"
  confidence:
    # Per-tier surfacing confidence flags. Flipped by the Telegram
    # /calibration_ok <tier> command. Read by future c3/c4/c5
    # surfacing layers — nothing reads them in c2 yet.
    high: false
    medium: false
    low: false
    spam: false
  state:
    path: "./data/daily_sync_state.json"
  # Attribution-audit section — Phase 2 of the calibration audit gap
  # arc (see ``project_calibration_audit_gap.md``). Surfaces agent-
  # inferred vault content (marked by BEGIN_INFERRED/END_INFERRED
  # comment pairs + ``attribution_audit`` frontmatter entries) in the
  # Daily Sync so Andrew can reply ``N confirm`` (flip the marker to
  # confirmed) or ``N reject`` (strip the section + log).
  #
  # Absent block ≡ enabled (default). Set ``enabled: false`` to omit
  # the attribution section entirely while keeping the rest of the
  # Daily Sync running.
  attribution:
    enabled: true
    batch_size: 5
    # Vault paths to scan for attribution_audit entries. Leave empty
    # (default) to scan the whole vault. Restrict for performance
    # once the vault grows past ~10k records; typical values are
    # vault-relative subpaths like ["note", "person", "process"].
    scan_paths: []
    # Attribution-audit corpus path (separate from the email
    # calibration corpus above). Append-only JSONL; one row per
    # Andrew confirm or reject action.
    corpus_path: "./data/attribution_audit_corpus.jsonl"

# Pending Items Queue (Phase 1) — items only Andrew can answer.
# Per-instance JSONL queue (data/pending_items.jsonl) + auto-
# regenerated vault markdown view (vault/process/Pending Items.md).
# Salem aggregates cross-instance queues via /peer/pending_items_push;
# resolutions route back to the originator via /peer/pending_items_resolve.
#
# Phase 1 surfaces ``outbound_failure`` items (auto-emitted from
# session frontmatter). Phase 2 will add unanswered_clarification
# and fuzzy_match. Phase 3 implements the full action plan executor.
#
# Per-instance config: every instance with a talker daemon writes
# to its local queue. Salem aggregates from peers; peer instances
# (Hypatia, KAL-LE) set ``push.target_peer: "salem"`` so the pusher
# daemon flushes their local queue to Salem on a periodic cadence.
pending_items:
  enabled: true
  queue_path: "./data/pending_items.jsonl"
  view_path: "process/Pending Items.md"
  view_debounce_seconds: 30
  push:
    # Salem leaves target_peer empty — it aggregates inbound pushes
    # rather than pushing outbound. Hypatia / KAL-LE override:
    #   target_peer: "salem"
    #   self_name: "hypatia"
    target_peer: ""
    self_name: ""
    interval_seconds: 300       # 5-minute periodic flush
  expiry:
    stale_days: 7               # items older than this render as "(stale)"
    expire_days: 14             # auto-expired after this
  outbound_failure_detector:
    enabled: true
    state_path: "./data/pending_items_outbound_failure_state.json"
    session_subpath: "session"

bit:
  # BIT (built-in test) runs before the Morning Brief so the brief can
  # report on system health. By default it fires 5 minutes before
  # ``brief.schedule.time``; override with ``schedule.time: HH:MM``.
  # ``mode`` is ``quick`` (5s per tool) or ``full`` (15s per tool).
  schedule:
    # time: "05:55"          # explicit HH:MM; empty = derive from brief
    lead_minutes: 5          # subtract this from brief time
    # timezone: "America/Halifax"  # empty = use brief's timezone
    mode: "quick"
  output:
    directory: "run"
    name_template: "Alfred BIT {date}"
  state:
    path: "./data/bit_state.json"
    max_history: 30

# Routine — Salem-only daily routine tracker (Phase 1).
#
# Replaces Trello-style daily templates with a vault-native record set.
# Each ``routine/<name>.md`` defines a cadence (daily/weekly/every_n_days/
# monthly/every_n_months) and a list of items with priority
# (critical/tracked/aspirational). The daemon fires at 05:59 Halifax
# (one minute before the brief) and writes ``vault/daily/<date>.md``
# aggregating every routine that fires today, grouped by priority.
# The brief reads that file and inlines it as the "Today's Routines"
# section between Weather and Operations.
#
# Salem-only: the daemon refuses to start on any other instance
# (telegram.instance.name != "Salem" → exit 78). Hypatia and KAL-LE
# should leave this block absent in their config.<instance>.yaml.
#
# Phase 2 will surface ``alfred routine done <record> <item>`` through
# Telegram and may relax the Salem-only constraint.
routine:
  enabled: true
  schedule:
    time: "05:59"                   # 1 minute before brief at 06:00
    timezone: "America/Halifax"
  output:
    directory: "daily"              # ``vault/daily/<date>.md`` lives here
    name_template: "{date}"
  state:
    path: "./data/routine_state.json"
    max_history: 30

surveyor:
  watcher:
    debounce_seconds: 30
  ollama:
    base_url: "http://localhost:11434"
    model: "nomic-embed-text"
    embedding_dims: 768
    # api_key: "${OPENROUTER_API_KEY}"  # If set, uses OpenAI-compatible /v1/embeddings endpoint
    # When using OpenRouter for embeddings, set:
    #   base_url: "https://openrouter.ai/api/v1"
    #   model: "openai/text-embedding-3-small"
    #   embedding_dims: 1536
    #   api_key: "${OPENROUTER_API_KEY}"
  milvus:
    uri: "./data/milvus_lite.db"
    collection_name: "vault_embeddings"
  clustering:
    hdbscan:
      min_cluster_size: 3
      min_samples: 2
    leiden:
      resolution: 1.0
  openrouter:
    api_key: "${OPENROUTER_API_KEY}"
    base_url: "https://openrouter.ai/api/v1"
    model: "x-ai/grok-4.1-fast"
    temperature: 0.3
  labeler:
    max_files_per_cluster_context: 20
    body_preview_chars: 200
    min_cluster_size_to_label: 2
    # Drop any LLM-suggested relationship whose confidence is below this gate.
    # Raised from the historical 0.5 default to filter out low-grounding guesses.
    min_relationship_confidence: 0.65
  state:
    path: "./data/surveyor_state.json"
  # Idle-tick heartbeat — counter semantic: one record re-embedded =
  # one event. The labeling pass is downstream of embedding and runs at
  # most once per cluster change, so embedding is the more meaningful
  # per-record signal. Defaults on; see
  # ``src/alfred/common/heartbeat.py``.
  idle_tick:
    enabled: true
    interval_seconds: 60

# Cloudflared tunnel supervisor — wraps the ``cloudflared`` Go binary as
# a supervised child of ``alfred up`` so the Cloudflare tunnel auto-
# restarts with the other daemons (rather than running manually via
# ``nohup cloudflared tunnel run <id> &``).
#
# Background: on 2026-05-13 we discovered the Outlook → mail webhook
# pipeline had been silently disconnected for ~2 weeks because the
# manually-started cloudflared process stopped after a WSL2 restart
# and nobody noticed. Bringing the tunnel under ``alfred up`` closes
# that observability gap (auto-restart up to 5 times, structured
# ``cloudflared.started`` / ``cloudflared.exited`` events in
# ``data/alfred.log``).
#
# Per-instance opt-in (conservative — needs explicit ``enabled: true``,
# not just block presence). Salem turns it on for the mail webhook
# bridge; KAL-LE / Hypatia / instances without an exposed tunnel leave
# the block out entirely.
#
# Detect-and-takeover: ``alfred up`` probes ``localhost:<metrics_port>/metrics``
# at startup. If an existing cloudflared instance is already serving
# (e.g. from a manual ``cloudflared tunnel run`` in another terminal),
# the supervisor logs ``cloudflared.existing_instance_detected`` and
# exits 78 — no double-spawn, no port conflict. Operator handoff: run
# ``pkill cloudflared`` to kill the manual instance, then ``alfred up``
# will spawn its own supervised copy on next restart.
#
# Required:
#   tunnel_id    — UUID of the cloudflared tunnel (from Cloudflare dash).
#
# Optional:
#   config_path  — Override the default ``~/.cloudflared/config.yml``.
#   binary_path  — Override the default ``/usr/local/bin/cloudflared``.
#   log_path     — Override the default ``<logging.dir>/cloudflared.log``.
#   metrics_port — Override the default ``20241`` (the port cloudflared
#                  binds for ``/metrics``; also used by the startup
#                  detect-and-takeover probe).
# cloudflared:
#   enabled: false
#   tunnel_id: ""
#   config_path: "~/.cloudflared/config.yml"
#   binary_path: "/usr/local/bin/cloudflared"
#   log_path: "./data/cloudflared.log"
#   metrics_port: 20241

# Optional. Tunes ``alfred scaffold sync`` (Build #38 — diff-and-copy
# of bundled scaffold content into an existing instance vault). The
# block is OPTIONAL; when absent, the module-level Salem-shape default
# applies (the same list shown below as ``include``).
#
# Three-layer precedence (highest wins) for the resolved sync filter:
#   1. CLI flag ``--include`` / ``--exclude`` (operator override)
#   2. This config block (per-instance default)
#   3. Module-level ``DEFAULT_INCLUDE`` / ``DEFAULT_EXCLUDE``
#      (Salem-shape fallback — what this example shows)
#
# Per-instance customization: KAL-LE and Hypatia (canonical-curation
# and knowledge-work shapes respectively) override this block in their
# ``config.<instance>.yaml`` files with a trimmed include set — just
# the top-level docs (README.md, Start Here.md, user-profile.md) —
# because the per-record-type templates and base-views shipped in the
# scaffold are Salem-operational-vault shape and would write 50+ dead
# files into vaults that don't use those record types. Trimmed shape:
#
#   scaffold:
#     include: ["README.md", "Start Here.md", "user-profile.md"]
#     exclude: [".obsidian", ".gitkeep"]
#
# Empty-list semantics: ``include: []`` is honored — operator can opt
# out of all auto-sync via an explicit empty list. The ``no_candidates``
# empty-state signal fires downstream so idle is distinguishable from
# broken.
scaffold:
  include:
    - "_templates"
    - "_bases"
    - "view"
    - "CLAUDE.md"
    - "README.md"
    - "Start Here.md"
    - "user-profile.md"
  exclude:
    - ".obsidian"
    - ".gitkeep"

# GitHub ops — KAL-LE-ONLY GitHub access for the VERA→KAL-LE→GitHub
# ticket pipeline (ratified 2026-06-11). Exactly one instance holds a
# GitHub credential: a fine-grained PAT scoped to ONE repo with
# Issues RW + Pull requests READ + Metadata R. Other instances leave
# this block out entirely — ``build_github_client`` additionally
# fail-louds when the running instance's name doesn't match
# ``instance`` below (the code-gate half of the privilege boundary).
#
# The env var name is operator-chosen and deliberately NOT
# ALFRED_*-prefixed (it's an Algernon-platform credential, not a
# legacy-namespace one).
#
# label_map: optional ticket_type / priority value → GitHub label(s).
# A value may be a single label ("bug") OR a list (["bug", "auto-fix"]);
# bare strings normalize to 1-element lists, so the single-string form
# still works. The resolved per-issue set is ``labels`` below + every
# matched label_map value, flattened, de-duplicated, order-stable.
# Unmapped values get no extra label (each logs label_unmapped once).
#
# Gating the auto-fix label to BUG tickets (the recommended pattern):
# put ``auto-fix`` only on the bug mapping, leave base ``labels`` empty.
# A bug then files an issue WITH ``auto-fix`` (the claude-auto-fix.yml
# workflow fires at creation); an enhancement files a tracked issue
# WITHOUT it (the operator promotes it later by adding the label).
# github:
#   repo: "newtonium-errant/transport-admin-portal"
#   pat: "${ALGERNON_KALLE_GITHUB_PAT}"
#   # CASE-SENSITIVE: must equal telegram.instance.name EXACTLY
#   # ("KAL-LE", not "kal-le") — build_github_client's instance gate
#   # does a strict string compare and fail-louds on mismatch.
#   instance: "KAL-LE"
#   labels: []
#   label_map:
#     bug: ["bug", "auto-fix"]
#     enhancement: ["enhancement"]
#     p1: "priority-high"   # single-string form still accepted
#   audit_log_path: "./data/github_ops_audit.jsonl"

# Ticket intake — KAL-LE-ONLY receiver half of the VERA→KAL-LE→GitHub
# ticket pipeline (ratified 2026-06-11; see integrations/github_ops.py
# for the architecture). VERA pushes kind=ticket over the peer
# protocol; the intake records the ticket in this instance's vault
# (scope kalle) and files the GitHub issue. Requires the github: block
# above — the talker daemon registers the intake only when BOTH are
# present and the GitHub client builds (a broken github: config logs
# transport.ticket_intake.disabled and kind=ticket answers 501).
# NOTE: github.instance must exactly match this instance's
# telegram.instance.name. labels/label_map live on github: (one home).
# Live wiring (the per-peer token blocks that let VERA reach this
# instance) is per-instance config — see the transport.peers example.
# ticket_intake:
#   enabled: true
#   state:
#     path: "./data/ticket_intake_state.json"

# Ticket forwarder — VERA-ONLY sender half of the same pipeline.
# Deterministic 15-minute scanner over <vault>/ticket/: every ticket
# with status: open and no linked GitHub issue is pushed to the intake
# peer as kind=ticket (no LLM, no operator gate; enabled is the
# kill-switch). The ack's issue link-back is written onto the record
# via the narrow vera_forwarder scope. vault_path falls back to
# vault.path when omitted. target_peer must name an entry in THIS
# instance's transport.peers block (token + base_url — see the
# transport.peers example for the live wiring).
# ticket_forward:
#   enabled: true
#   self_name: "vera"
#   target_peer: "kalle"
#   interval_minutes: 15
#   state:
#     path: "./data/ticket_forward_state.json"

# Ticket outcome write-back (pipeline c7) — closes the loop the other
# direction (KAL-LE→VERA). When KAL-LE's nightly effectiveness loop sees
# a tracked GitHub issue reach a terminal disposition (merged / closed),
# it pushes the outcome to the origin instance so the ORIGINATING ticket
# flips out of the open worklist (status → resolved | closed). ONE
# section, TWO independent roles — each instance sets only its side:
#   * KAL-LE (pusher):   enabled: true + self_name + target_peer.
#   * VERA (receiver):   receiver_enabled: true (wires the
#                        /peer/ticket_outcome resolver + advertises the
#                        ticket_outcome handshake capability).
# Idempotent (pushed once per terminal transition); fail-closed (a push
# failure leaves KAL-LE's own state authoritative and retries next
# night). Uses a DEDICATED per-direction peer token (KAL-LE→VERA),
# distinct from the VERA→KAL-LE intake token — see .env.example. Live
# wiring (transport.peers.vera on KAL-LE + transport.auth.tokens.kalle
# on VERA) is per-instance config.
# --- on KAL-LE: ---
# ticket_outcome:
#   enabled: true
#   self_name: "kal-le"
#   target_peer: "vera"
# --- on VERA: ---
# ticket_outcome:
#   receiver_enabled: true
