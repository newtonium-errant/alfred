# Algernon instance registry — fan-out target for
# ``alfred instance up | down | status``.
#
# Copy this file into place:
#     cp instances.yaml.example ~/.alfred/instances.yaml
#
# Then edit as needed for your installation. Each entry needs:
#   - ``name`` (lowercase slug, e.g. ``salem``, ``kal-le``)
#   - ``display`` (operator-facing name, e.g. ``Salem``, ``KAL-LE``)
#   - ``config`` (path to the instance's config.yaml — see note below)
#   - ``enabled`` (optional, defaults to ``true``) — set to ``false``
#     to drain an instance from fan-out without deleting the row
#
# Config path conventions:
#   - Relative paths (``./config.yaml``) resolve against the cwd at
#     the moment ``alfred instance up | down | status`` runs. Typical
#     workflow: ``cd <project-root> && alfred instance up`` — the
#     relative paths below work directly for an operator who clones
#     the repo + has configs at the canonical layout.
#   - Absolute paths (``/home/<user>/alfred/config.yaml``) are
#     cwd-independent but require an edit per machine.
#   - Choose whichever matches your launch convention.
#
# Order is preserved in operator-facing output, so put the most-
# critical instance first (Salem here, by convention).

instances:
  - name: salem
    display: Salem
    config: ./config.yaml
    enabled: true
  - name: kal-le
    display: KAL-LE
    config: ./config.kalle.yaml
    enabled: true
  - name: hypatia
    display: Hypatia
    config: ./config.hypatia.yaml
    enabled: true
