# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# Runtime data
data/
!data/.gitkeep

# Config with secrets
.env
config.yaml
# Per-instance configs (config.kalle.yaml, config.stayc.yaml, etc.) —
# each holds its own secrets/tokens and should not be checked in.
config.*.yaml
!config.*.yaml.example
# Manual config backups taken before risky changes (e.g.
# config.yaml.bak.before_classifier). Same hygiene as config.yaml.
config.yaml.bak.*

# IDE
.vscode/
.idea/

# Claude Code local state (per-project session cache, not shared)
.claude/projects/
# Runtime lockfile written by the /schedule skill.
.claude/scheduled_tasks.lock
# Agent isolation worktrees created by the Agent tool's isolation: "worktree".
.claude/worktrees/

# Ink TUI
tui-ink/node_modules/
tui-ink/dist/

# Private repos (separate standalone repos, not part of this monorepo)
alfred-ctrl/
alfred-saas/
alfred-docs/
alfred-documentation/

# Finished n8n workflows (local only, repo is for coding knowledge)
workflows/

# Vault is a self-contained nested git repo (vault/.git) with its own daily
# snapshot system — the outer repo tracks NONE of it. Untracked 2026-06-25:
# session/ + process/ were formerly tracked here, which made a git-on-box
# `reset --hard` able to clobber the live vault. Now fully box-local and
# owned by the nested repo (also keeps talker conversation records off GitHub).
/vault/

# Pytest / coverage artifacts
htmlcov/
.coverage
.coverage.*
coverage.xml

# OS
.DS_Store
Thumbs.db
.msgbus/
