# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# Runtime data
data/
!data/.gitkeep

# Config with secrets
.env
config.yaml
# Per-instance configs (config.kalle.yaml, config.stayc.yaml, etc.) —
# each holds its own secrets/tokens and should not be checked in.
config.*.yaml
!config.*.yaml.example

# IDE
.vscode/
.idea/

# Claude Code local state (per-project session cache, not shared)
.claude/projects/
# Runtime lockfile written by the /schedule skill.
.claude/scheduled_tasks.lock

# Ink TUI
tui-ink/node_modules/
tui-ink/dist/

# Private repos (separate standalone repos, not part of this monorepo)
alfred-ctrl/
alfred-saas/
alfred-docs/
alfred-documentation/

# Finished n8n workflows (local only, repo is for coding knowledge)
workflows/

# Vault: only session/ and process/ live in the outer repo.
# Everything else under vault/ is tracked by the nested vault git repo
# used by the snapshot system. Do not add it here or it will double-track.
/vault/*
!/vault/session/
!/vault/process/

# Pytest / coverage artifacts
htmlcov/
.coverage
.coverage.*
coverage.xml

# OS
.DS_Store
Thumbs.db
