# Algernon web frontend — local env. Copy to `.env.local` (gitignored).
#
# FE-1 (design system / shell): only the instance display name is read.
# The `NEXT_PUBLIC_` prefix inlines it into the browser bundle at build —
# it is NOT a secret (just the header/title label). Defaults to "Algernon".
NEXT_PUBLIC_INSTANCE_NAME=Salem

# --- FE-2 (BFF → transport) — server-side ONLY, never NEXT_PUBLIC_ ----------
# Required for the chat to function. The BFF reads these at request time.
# The transport base URL the BFF reaches (the talker daemon's aiohttp app).
# Default transport bind is 127.0.0.1:8891 (transport.server host/port).
# ALFRED_WEB_TRANSPORT_URL=http://127.0.0.1:8891
# The peer token (config `auth.tokens.web.token`). Held server-side in the BFF;
# the browser never sees it.
# ALFRED_WEB_PEER_TOKEN=
# The peer/client name the transport knows this front-end by — must match the
# backend's web peer entry in `auth.tokens`. Defaults to "web" if unset.
# ALFRED_WEB_PEER_CLIENT=web

# --- Local-dev session token (server-side ONLY) ----------------------------
# B3 live contract: /chat/* identity is the instance-signed session token,
# relayed as `X-Alfred-Session`. In normal use the token is minted by login
# (FE-3: /auth/verify) and stored in an httpOnly cookie. For local dev BEFORE
# the login UI — or to test /chat against the real backend without the Resend
# email round-trip — paste a token from the backend's dev handshake here and the
# BFF will use it as a fallback when no session cookie is present.
# ALFRED_WEB_DEV_SESSION_TOKEN=

# --- Web STT (voice) — no new env --------------------------------------------
# STT rides the SAME transport env as chat (ALFRED_WEB_TRANSPORT_URL /
# ALFRED_WEB_PEER_TOKEN / ALFRED_WEB_PEER_CLIENT) — the BFF relays the audio to
# the talker daemon's /stt/transcribe on the existing transport. No extra FE env.

# --- Cross-instance CHAT (instance switcher) — server-side ONLY --------------
# Lets the owner chat with OTHER instances (KAL-LE / Hypatia / VERA) from the web
# via the instance switcher. The HOME instance (NEXT_PUBLIC_INSTANCE_NAME, e.g.
# Salem) is ALWAYS available and rides the existing session path — do NOT add a
# CHAT env pair for it. One env PAIR per CROSS-INSTANCE target; a target appears
# in the switcher ONLY when BOTH its _URL and _TOKEN are set (fail-closed). The
# BFF is the SOLE holder of these tokens — the browser only ever sees
# {name, label} via /api/chat/targets.
#
#   ALFRED_WEB_CHAT_<NAME>_URL    transport base URL of the target (loopback)
#   ALFRED_WEB_CHAT_<NAME>_TOKEN  that target's DEDICATED `web` peer token — the
#                                 full-talker-scope chat token. MUST be DISTINCT
#                                 from that instance's `web_ingest` token and from
#                                 every other instance's token (decision M4).
#   ALFRED_WEB_CHAT_<NAME>_LABEL  (optional) display label; defaults to <NAME>
#
# <NAME> is the switcher's instance value (letters/digits/underscore). Ports:
# KAL-LE 8892, Hypatia 8893, VERA 8894 (all 127.0.0.1, loopback-only).
# ALFRED_WEB_CHAT_KALLE_URL=http://127.0.0.1:8892
# ALFRED_WEB_CHAT_KALLE_TOKEN=
# ALFRED_WEB_CHAT_KALLE_LABEL=KAL-LE
# ALFRED_WEB_CHAT_HYPATIA_URL=http://127.0.0.1:8893
# ALFRED_WEB_CHAT_HYPATIA_TOKEN=
# ALFRED_WEB_CHAT_HYPATIA_LABEL=Hypatia
# ALFRED_WEB_CHAT_VERA_URL=http://127.0.0.1:8894
# ALFRED_WEB_CHAT_VERA_TOKEN=
# ALFRED_WEB_CHAT_VERA_LABEL=VERA

# --- Cross-instance ingest — server-side ONLY, never NEXT_PUBLIC_ -------------
# One env PAIR per ingest target instance the operator may write to. A target
# appears in the picker ONLY when BOTH its _URL and _TOKEN are set (fail-closed);
# a half-configured target is skipped. The BFF is the SOLE holder of these tokens
# — the browser only ever sees {name, label, recordTypes} via /api/ingest/targets.
#
#   ALFRED_WEB_INGEST_<NAME>_URL    transport base URL of the target (loopback)
#   ALFRED_WEB_INGEST_<NAME>_TOKEN  that target's DEDICATED `web_ingest` peer token
#                                   (distinct per target — never reuse the chat
#                                   `web` token or another target's token)
#   ALFRED_WEB_INGEST_<NAME>_LABEL  (optional) display label; defaults to <NAME>
#
# <NAME> is the picker's `target` value (letters/digits/underscore). Ports:
# Salem 8891, KAL-LE 8892, Hypatia 8893, VERA 8894 (all 127.0.0.1, loopback-only).
# ALFRED_WEB_INGEST_SALEM_URL=http://127.0.0.1:8891
# ALFRED_WEB_INGEST_SALEM_TOKEN=
# ALFRED_WEB_INGEST_SALEM_LABEL=Salem
# ALFRED_WEB_INGEST_KALLE_URL=http://127.0.0.1:8892
# ALFRED_WEB_INGEST_KALLE_TOKEN=
# ALFRED_WEB_INGEST_KALLE_LABEL=KAL-LE
# ALFRED_WEB_INGEST_HYPATIA_URL=http://127.0.0.1:8893
# ALFRED_WEB_INGEST_HYPATIA_TOKEN=
# ALFRED_WEB_INGEST_HYPATIA_LABEL=Hypatia
# ALFRED_WEB_INGEST_VERA_URL=http://127.0.0.1:8894
# ALFRED_WEB_INGEST_VERA_TOKEN=
# ALFRED_WEB_INGEST_VERA_LABEL=VERA
