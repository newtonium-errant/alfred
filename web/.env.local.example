# Algernon web frontend — local env. Copy to `.env.local` (gitignored).
#
# FE-1 (design system / shell): only the instance display name is read.
# The `NEXT_PUBLIC_` prefix inlines it into the browser bundle at build —
# it is NOT a secret (just the header/title label). Defaults to "Algernon".
NEXT_PUBLIC_INSTANCE_NAME=Salem

# --- FE-2 (BFF → transport) — server-side ONLY, never NEXT_PUBLIC_ ----------
# Required for the chat to function. The BFF reads these at request time.
# The transport base URL the BFF reaches (the talker daemon's aiohttp app).
# ALFRED_WEB_TRANSPORT_URL=http://127.0.0.1:8765
# The peer token (config `auth.tokens.web.token`). Held server-side in the BFF;
# the browser never sees it.
# ALFRED_WEB_PEER_TOKEN=
# The peer/client name the transport knows this front-end by — must match the
# backend's web peer entry in `auth.tokens`. Defaults to "web" if unset.
# ALFRED_WEB_PEER_CLIENT=web

# --- Local-dev session token (server-side ONLY) ----------------------------
# B3 live contract: /chat/* identity is the instance-signed session token,
# relayed as `X-Alfred-Session`. In normal use the token is minted by login
# (FE-3: /auth/verify) and stored in an httpOnly cookie. For local dev BEFORE
# the login UI — or to test /chat against the real backend without the Resend
# email round-trip — paste a token from the backend's dev handshake here and the
# BFF will use it as a fallback when no session cookie is present.
# ALFRED_WEB_DEV_SESSION_TOKEN=
