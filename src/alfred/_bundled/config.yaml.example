vault:
  path: "./vault"
  # Two semantically distinct exclusion fields (split 2026-05-01):
  #
  # ``dont_scan_dirs`` — directories whose records should NOT be scanned
  #   for issues. Top-level entries match any path component (.obsidian
  #   anywhere); nested entries (``inbox/processed``) match a path prefix
  #   (so the curator's processed audit is excluded but fresh ``inbox/``
  #   items are still visible). Replaces legacy ``ignore_dirs`` — same
  #   meaning. Set ONLY the legacy key and it works as a back-compat
  #   shim, but ``dont_index_dirs`` then defaults to empty (the bug fix).
  #
  # ``dont_index_dirs`` — directories that should NOT contribute records
  #   to janitor's valid-wikilink-target stem index. Default empty: any
  #   on-disk record is a valid link target unless explicitly excluded.
  dont_scan_dirs: ["_templates", "_bases", "_docs", ".obsidian", "view", "inbox/processed"]
  dont_index_dirs: []
  ignore_files: [".gitkeep"]

agent:
  backend: "claude"
  claude:
    command: "claude"
    args: ["-p"]
    timeout: 600
    allowed_tools: ["Bash"]
  zo:
    url: "https://api.zo.computer/zo/ask"
    method: "POST"
    headers:
      Authorization: "Bearer ${ZO_API_KEY}"
    request_body_template:
      message: "{prompt}"
    response_content_path: "response.content"
    timeout: 600
  openclaw:
    command: "openclaw"
    args: []
    workspace_mount: ""
    timeout: 600

logging:
  level: "INFO"
  dir: "./data"

curator:
  inbox_dir: "inbox"
  processed_dir: "inbox/processed"
  watcher:
    poll_interval: 5
    debounce_seconds: 10
  state:
    path: "./data/curator_state.json"

janitor:
  sweep:
    interval_seconds: 3600
    deep_sweep_interval_hours: 24
    structural_only: false
    stub_body_threshold_chars: 50
    orphan_exempt_dirs: ["view"]
    max_files_per_agent_call: 30
    fix_log_in_vault: true
  state:
    path: "./data/janitor_state.json"
    max_sweep_history: 20

distiller:
  extraction:
    interval_seconds: 3600
    deep_interval_hours: 24
    candidate_threshold: 0.3
    max_sources_per_batch: 20
    source_types: ["conversation", "session", "note", "task", "project"]
    learn_types: ["assumption", "decision", "constraint", "contradiction", "synthesis"]
  state:
    path: "./data/distiller_state.json"
    max_run_history: 20

surveyor:
  watcher:
    debounce_seconds: 30
  ollama:
    base_url: "http://localhost:11434"
    model: "nomic-embed-text"
    embedding_dims: 768
    # api_key: "${OPENROUTER_API_KEY}"  # If set, uses OpenAI-compatible /v1/embeddings endpoint
    # When using OpenRouter for embeddings, set:
    #   base_url: "https://openrouter.ai/api/v1"
    #   model: "openai/text-embedding-3-small"
    #   embedding_dims: 1536
    #   api_key: "${OPENROUTER_API_KEY}"
  milvus:
    uri: "./data/milvus_lite.db"
    collection_name: "vault_embeddings"
  clustering:
    hdbscan:
      min_cluster_size: 3
      min_samples: 2
    leiden:
      resolution: 1.0
  openrouter:
    api_key: "${OPENROUTER_API_KEY}"
    base_url: "https://openrouter.ai/api/v1"
    model: "x-ai/grok-4.1-fast"
    temperature: 0.3
  labeler:
    max_files_per_cluster_context: 20
    body_preview_chars: 200
    min_cluster_size_to_label: 2
  state:
    path: "./data/surveyor_state.json"
